{
  "properties": {
    "name": "RisingWave",
    "realName": "RisingWave",
    "icon": "icons/risingwave.png",
    "doc": "${doc}",
    "id": "risingwave",
    "tags": [
      "Database",
      "Streaming"
    ]
  },
  "configOptions": {
    "capabilities": [
      {
        "id": "dml_insert_policy",
        "alternatives": [
          "update_on_exists",
          "just_insert"
        ]
      },
      {
        "id": "dml_update_policy",
        "alternatives": [
          "ignore_on_nonexists",
          "insert_on_nonexists"
        ]
      },
      {
        "id": "dml_delete_policy",
        "alternatives": [
          "ignore_on_nonexists"
        ]
      }
    ],
    "connection": {
      "type": "object",
      "properties": {
        "host": {
          "required": true,
          "type": "string",
          "title": "${host}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-decorator-props": {
            "tooltip": "${hostTip}"
          },
          "x-index": 10
        },
        "port": {
          "required": true,
          "type": "number",
          "title": "${port}",
          "default": 4566,
          "x-decorator": "FormItem",
          "x-component": "InputNumber",
          "x-decorator-props": {
            "tooltip": "${portTip}"
          },
          "x-index": 20
        },
        "database": {
          "required": true,
          "type": "string",
          "title": "${database}",
          "default": "dev",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-decorator-props": {
            "tooltip": "${databaseTip}"
          },
          "x-index": 30
        },
        "schema": {
          "required": false,
          "type": "string",
          "title": "${schema}",
          "default": "public",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-decorator-props": {
            "tooltip": "${schemaTip}"
          },
          "x-index": 40
        },
        "user": {
          "required": true,
          "type": "string",
          "title": "${user}",
          "default": "root",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-decorator-props": {
            "tooltip": "${userTip}"
          },
          "x-index": 50
        },
        "password": {
          "type": "string",
          "title": "${password}",
          "x-decorator": "FormItem",
          "x-component": "Password",
          "x-decorator-props": {
            "tooltip": "${passwordTip}"
          },
          "x-index": 60
        },
        "ingest_mode": {
          "required": false,
          "type": "string",
          "title": "${ingestMode}",
          "default": "streaming",
          "x-decorator": "FormItem",
          "x-component": "Select",
          "x-decorator-props": {
            "tooltip": "${ingestModeTip}"
          },
          "x-component-props": {
            "options": [
              {"label": "WebSocket streaming (recommended)", "value": "streaming"},
              {"label": "WebSocket JSONB append-only", "value": "streaming_jsonb"},
              {"label": "JDBC (compatible)", "value": "jdbc"}
            ]
          },
          "x-index": 70
        },
        "ingestEndpoint": {
          "required": false,
          "type": "string",
          "title": "${ingestEndpoint}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-decorator-props": {
            "tooltip": "${ingestEndpointTip}"
          },
          "x-component-props": {
            "placeholder": "${ingestEndpointPlaceholder}"
          },
          "x-reactions": {
            "dependencies": ["ingest_mode"],
            "fulfill": {
              "state": {
                "visible": "{{$deps[0] === 'streaming' || $deps[0] === 'streaming_jsonb'}}"
              }
            }
          },
          "x-index": 80
        },
        "webhookSecret": {
          "required": false,
          "type": "string",
          "title": "${webhookSecret}",
          "x-decorator": "FormItem",
          "x-component": "Password",
          "x-decorator-props": {
            "tooltip": "${webhookSecretTip}"
          },
          "x-reactions": {
            "dependencies": ["ingest_mode"],
            "fulfill": {
              "state": {
                "visible": "{{$deps[0] === 'streaming' || $deps[0] === 'streaming_jsonb'}}"
              }
            }
          },
          "x-index": 90
        },
        "OPTIONAL_FIELDS": {
          "type": "void",
          "properties": {
            "sslmode": {
              "required": false,
              "type": "string",
              "title": "${sslmode}",
              "default": "prefer",
              "x-decorator": "FormItem",
              "x-component": "Select",
              "x-decorator-props": {
                "tooltip": "${sslmodeTip}"
              },
              "x-component-props": {
                "options": [
                  {"label": "Prefer (recommended)", "value": "prefer"},
                  {"label": "Require", "value": "require"},
                  {"label": "Disable", "value": "disable"}
                ]
              },
              "x-index": 100
            },
            "extParams": {
              "required": false,
              "type": "string",
              "title": "${extParams}",
              "x-decorator": "FormItem",
              "x-component": "Input",
              "x-decorator-props": {
                "tooltip": "${extParamsTip}"
              },
              "x-index": 110
            },
            "timezone": {
              "required": false,
              "type": "string",
              "title": "${timezone}",
              "default": "",
              "x-decorator": "FormItem",
              "x-component": "Input",
              "x-decorator-props": {
                "tooltip": "${timezoneTip}"
              },
              "x-component-props": {
                "placeholder": "UTC or Asia/Shanghai"
              },
              "x-index": 120
            }
          }
        }
      }
    }
  },
  "messages": {
    "default": "en_US",
    "en_US": {
      "doc": "docs/risingwave_en_US.md",
      "host": "Host",
      "hostTip": "RisingWave server hostname or IP address",
      "port": "Port",
      "portTip": "RisingWave server port (default: 4566)",
      "database": "Database",
      "databaseTip": "RisingWave database name (default: dev)",
      "schema": "Schema",
      "schemaTip": "Target schema (default: public)",
      "user": "User",
      "userTip": "Database user (default: root)",
      "password": "Password",
      "passwordTip": "Database password (leave empty if none)",
      "ingestMode": "Write Mode",
      "ingestModeTip": "WebSocket streaming supports insert, update, and delete and requires a primary key. WebSocket JSONB append-only stores each inserted source record in one data JSONB column without requiring a primary key, but rejects updates and deletes. JDBC is the compatible fallback.",
      "ingestEndpoint": "Ingest Endpoint",
      "ingestEndpointPlaceholder": "Leave blank to use ws://<Host>:4560 automatically",
      "ingestEndpointTip": "Optional WebSocket ingest base endpoint, including scheme, for example ws://host:4560 locally or wss://cloud-host for Cloud port 443. Leave blank to derive ws://<Host>:4560 from the Host field. Set it explicitly for TLS or a separate ingest host.",
      "webhookSecret": "Webhook Secret",
      "webhookSecretTip": "Shared secret used to sign the initial WebSocket auth frame when the target RisingWave table uses VALIDATE.",
      "sslmode": "SSL Mode",
      "sslmodeTip": "SSL connection mode. Use 'prefer' for local (auto-negotiate) or 'require' for RisingWave Cloud.",
      "extParams": "Extra Parameters",
      "extParamsTip": "Additional JDBC connection parameters, e.g. socketTimeout=60&tcpKeepAlive=true",
      "timezone": "Timezone",
      "timezoneTip": "RisingWave session timezone as an IANA name, for example UTC or Asia/Shanghai. Leave empty to use the server default."
    },
    "zh_CN": {
      "doc": "docs/risingwave_zh_CN.md",
      "host": "主机",
      "hostTip": "RisingWave 服务器主机名或 IP 地址",
      "port": "端口",
      "portTip": "RisingWave 服务器端口（默认：4566）",
      "database": "数据库",
      "databaseTip": "RisingWave 数据库名称（默认：dev）",
      "schema": "Schema",
      "schemaTip": "目标 Schema（默认：public）",
      "user": "用户名",
      "userTip": "数据库用户名（默认：root）",
      "password": "密码",
      "passwordTip": "数据库密码（无密码则留空）",
      "ingestMode": "写入模式",
      "ingestModeTip": "WebSocket 流式支持插入、更新和删除，并要求主键。WebSocket JSONB 仅追加模式把每条插入记录存入单个 data JSONB 列，不要求主键，但会拒绝更新和删除。JDBC 是兼容回退模式。",
      "ingestEndpoint": "Ingest 地址",
      "ingestEndpointPlaceholder": "留空将自动使用 ws://<主机>:4560",
      "ingestEndpointTip": "可选的 WebSocket ingest 基础地址，需包含协议，例如本地 ws://host:4560，或使用 443 端口的 Cloud 地址 wss://cloud-host。留空时根据主机字段自动使用 ws://<主机>:4560；TLS 或独立 ingest 主机时请显式填写。",
      "webhookSecret": "Webhook 密钥",
      "webhookSecretTip": "当目标 RisingWave 表使用 VALIDATE 时，用于签名初始 WebSocket 认证消息的共享密钥。",
      "sslmode": "SSL 模式",
      "sslmodeTip": "SSL 连接模式。本地用 'prefer'（自动协商），RisingWave Cloud 用 'require'。",
      "extParams": "额外参数",
      "extParamsTip": "额外的 JDBC 连接参数，例如 socketTimeout=60&tcpKeepAlive=true",
      "timezone": "时区",
      "timezoneTip": "RisingWave 会话时区，使用 IANA 名称，例如 UTC 或 Asia/Shanghai。留空使用服务端默认值。"
    }
  },
  "dataTypes": {
    "varchar[($byte)]": {
      "byte": 65535,
      "to": "TapString"
    },
    "text": {
      "byte": "2g",
      "to": "TapString"
    },
    "boolean": {
      "to": "TapBoolean"
    },
    "smallint": {
      "bit": 16,
      "priority": 3,
      "to": "TapNumber"
    },
    "integer": {
      "bit": 32,
      "priority": 2,
      "to": "TapNumber"
    },
    "bigint": {
      "bit": 64,
      "priority": 1,
      "to": "TapNumber"
    },
    "real": {
      "bit": 32,
      "to": "TapNumber"
    },
    "double precision": {
      "bit": 64,
      "to": "TapNumber"
    },
    "numeric": {
      "precision": [
        1,
        1000
      ],
      "scale": [
        0,
        1000
      ],
      "to": "TapNumber"
    },
    "date": {
      "range": [
        "0001-01-01",
        "9999-12-31"
      ],
      "pattern": "yyyy-MM-dd",
      "to": "TapDate"
    },
    "timestamp": {
      "range": [
        "0001-01-01 00:00:00",
        "9999-12-31 23:59:59"
      ],
      "pattern": "yyyy-MM-dd HH:mm:ss",
      "to": "TapDateTime"
    },
    "timestamp with time zone": {
      "range": [
        "0001-01-01 00:00:00",
        "9999-12-31 23:59:59"
      ],
      "pattern": "yyyy-MM-dd HH:mm:ss",
      "to": "TapDateTime"
    },
    "time": {
      "range": [
        "00:00:00",
        "23:59:59"
      ],
      "pattern": "HH:mm:ss",
      "to": "TapTime"
    },
    "bytea": {
      "to": "TapBinary"
    },
    "jsonb": {
      "to": "TapMap"
    },
    "json": {
      "to": "TapMap"
    }
  }
}
