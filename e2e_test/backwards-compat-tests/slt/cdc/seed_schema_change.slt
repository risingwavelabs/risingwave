# mysql

system ok
mysql --host=mysql --port=3306 -u root -p123456 -D rwcdc << EOF
ALTER TABLE table_in_mysql ADD COLUMN legacy_serial SERIAL;
EOF

query TTTT retry 10 backoff 3s
DESCRIBE mysql_table_in_rw;
----
id integer false NULL
name character varying false NULL
legacy_serial integer false NULL
_rw_timestamp timestamp with time zone true NULL
primary key id NULL NULL
distribution key id NULL NULL
table description mysql_table_in_rw NULL NULL
