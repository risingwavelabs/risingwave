statement ok
SET RW_IMPLICIT_FLUSH TO true;

# Keep the base table lightweight for the sink matrix.
statement ok
SET streaming_parallelism TO 1;

statement ok
SET streaming_parallelism_for_table TO 1;

statement ok
CREATE TABLE sp_base_t (v int);

# Fix the legacy system strategy to a single value so migration can materialize it deterministically.
statement ok
ALTER SYSTEM SET adaptive_parallelism_strategy TO 'BOUNDED(64)';

statement ok
SET streaming_parallelism TO default;

statement ok
SET streaming_parallelism_for_sink TO default;

statement ok
SET streaming_parallelism_strategy TO default;

statement ok
SET streaming_parallelism_strategy_for_sink TO default;

statement ok
CREATE SINK sk_dddd AS
SELECT * FROM sp_base_t
WITH (
    connector = 'blackhole',
    type = 'append-only',
    force_append_only = 'true'
);

statement ok
SET streaming_parallelism_strategy_for_sink TO 'bounded(16)';

statement ok
CREATE SINK sk_dddb AS
SELECT * FROM sp_base_t
WITH (
    connector = 'blackhole',
    type = 'append-only',
    force_append_only = 'true'
);

statement ok
SET streaming_parallelism_strategy_for_sink TO 'ratio(0.5)';

