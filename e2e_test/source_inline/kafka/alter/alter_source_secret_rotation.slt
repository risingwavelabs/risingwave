control substitution on

# ==== alter connection propagates secret rotation to dependent source ====

system ok
rpk topic create test_alter_conn_source_secret -X brokers=message_queue_sasl_1:19092 -X sasl.mechanism=PLAIN -X user=dev -X pass=rw

statement ok
create secret conn_source_password_1 with ( backend = 'meta' ) as 'rw';

statement ok
create secret conn_source_password_2 with ( backend = 'meta' ) as 'rw';

statement ok
create connection kafka_conn_source_secret with (
    type = 'kafka',
    properties.bootstrap.server = 'message_queue_sasl_1:19092',
    properties.security.protocol = 'SASL_PLAINTEXT',
    properties.sasl.mechanism = 'PLAIN',
    properties.sasl.username = 'dev',
    properties.sasl.password = secret conn_source_password_1
);

statement ok
create source s_conn_source_secret (x int) with (
    connector = 'kafka',
    connection = kafka_conn_source_secret,
    topic = 'test_alter_conn_source_secret'
) format plain encode json;

statement ok retry 5 backoff 3s
alter connection kafka_conn_source_secret connector with (
    properties.sasl.password = secret conn_source_password_2
);

query I
select count(*)
from rw_sources
where name = 's_conn_source_secret'
  and connector_props -> 'properties.sasl.password' ->> 'type' = 'secret'
  and connector_props -> 'properties.sasl.password' -> 'value' ->> 'value' = 'conn_source_password_2';
----
1

statement ok
drop secret conn_source_password_1;

statement error
drop secret conn_source_password_2;

statement ok
drop source s_conn_source_secret;

statement ok
drop connection kafka_conn_source_secret;

statement ok
drop secret conn_source_password_2;

# ==== direct alter source with secret rotation ====

system ok
rpk topic create test_alter_source_secret_direct -X brokers=message_queue_sasl_1:19092 -X sasl.mechanism=PLAIN -X user=dev -X pass=rw

statement ok
create secret source_password_1 with ( backend = 'meta' ) as 'rw';

statement ok
create secret source_password_2 with ( backend = 'meta' ) as 'rw';

statement ok
create source s_source_secret_direct (x int) with (
    connector = 'kafka',
    topic = 'test_alter_source_secret_direct',
    properties.bootstrap.server = 'message_queue_sasl_1:19092',
    properties.security.protocol = 'SASL_PLAINTEXT',
    properties.sasl.mechanism = 'PLAIN',
    properties.sasl.username = 'dev',
    properties.sasl.password = secret source_password_1
) format plain encode json;

statement ok retry 5 backoff 3s
ALTER SOURCE s_source_secret_direct CONNECTOR WITH (
    properties.sasl.password = secret source_password_2
);

query I
select count(*)
from rw_sources
where name = 's_source_secret_direct'
  and connector_props -> 'properties.sasl.password' ->> 'type' = 'secret'
  and connector_props -> 'properties.sasl.password' -> 'value' ->> 'value' = 'source_password_2';
----
1

statement ok
drop secret source_password_1;

statement error
drop secret source_password_2;

statement ok
drop source s_source_secret_direct;

statement ok
drop secret source_password_2;

system ok
rpk topic delete test_alter_conn_source_secret -X brokers=message_queue_sasl_1:19092 -X sasl.mechanism=PLAIN -X user=dev -X pass=rw

system ok
rpk topic delete test_alter_source_secret_direct -X brokers=message_queue_sasl_1:19092 -X sasl.mechanism=PLAIN -X user=dev -X pass=rw
