# Note: control substitution on will force us to use "\n" instead of "\n" in commands
control substitution on

# for non-shared source
statement ok
set streaming_use_shared_source to false;

system ok
rpk topic create test_secret_ref -p 3

statement ok
CREATE SECRET sec WITH (backend = 'meta') AS 'test_secret_ref';

statement ok
CREATE SOURCE s(x varchar)
WITH(
    ${RISEDEV_KAFKA_WITH_OPTIONS_COMMON},
    topic = secret sec,
    scan.startup.mode = 'earliest',
) FORMAT PLAIN ENCODE JSON;

statement error
DROP SECRET sec;

# ===== test ref secret in another schema =====

statement ok
create schema test_secret_dep_schema ;

statement ok
CREATE SECRET test_secret_dep_schema.sec_1 WITH (backend = 'meta') AS 'test_secret_ref';

statement ok
CREATE SOURCE s1(x varchar)
WITH(
    ${RISEDEV_KAFKA_WITH_OPTIONS_COMMON},
    topic = secret test_secret_dep_schema.sec_1,
    scan.startup.mode = 'earliest',
) FORMAT PLAIN ENCODE JSON;

statement error
DROP SECRET test_secret_dep_schema.sec_1;

# ===== end =====

# ===== cleanup =====

statement ok
DROP SOURCE s;

statement ok
DROP SECRET sec;

statement ok
drop source s1;

statement ok
drop secret test_secret_dep_schema.sec_1;

statement ok
set streaming_use_shared_source to true;

# Verify SHOW SOURCES visibility in the Kafka docker environment.
system ok
rpk topic create show_acl_source_topic -p 1 || true

statement ok
CREATE USER show_acl_source_user WITH PASSWORD 'password';

statement ok
GRANT CONNECT ON DATABASE "${SLT_DB}" TO show_acl_source_user;

statement ok
CREATE SCHEMA show_acl_source;

statement ok
GRANT USAGE ON SCHEMA show_acl_source TO show_acl_source_user;

statement ok
CREATE SECRET show_acl_source.hidden_topic WITH (backend = 'meta') AS 'show_acl_source_topic';

statement ok
CREATE SOURCE show_acl_source.hidden_source(x varchar)
WITH(
    ${RISEDEV_KAFKA_WITH_OPTIONS_COMMON},
    topic = secret show_acl_source.hidden_topic,
    scan.startup.mode = 'earliest'
) FORMAT PLAIN ENCODE JSON;

system ok
bash -c 'set -euo pipefail; out=$(PGPASSWORD=password psql -h "$SLT_HOST" -p "$SLT_PORT" -U show_acl_source_user -d "$SLT_DB" -Atc "SHOW SOURCES FROM show_acl_source;"); ! grep -q "hidden_source" <<<"$out"'

statement ok
GRANT SELECT ON SOURCE show_acl_source.hidden_source TO show_acl_source_user;

system ok
bash -c 'set -euo pipefail; out=$(PGPASSWORD=password psql -h "$SLT_HOST" -p "$SLT_PORT" -U show_acl_source_user -d "$SLT_DB" -Atc "SHOW SOURCES FROM show_acl_source;"); grep -q "hidden_source" <<<"$out"'

statement ok
DROP SOURCE show_acl_source.hidden_source;

statement ok
DROP SECRET show_acl_source.hidden_topic;

statement ok
DROP SCHEMA show_acl_source;

statement ok
DROP USER show_acl_source_user;

system ok
rpk topic delete show_acl_source_topic || true;
