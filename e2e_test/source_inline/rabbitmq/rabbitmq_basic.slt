control substitution on

statement ok
set streaming_use_shared_source to false;

statement ok
set streaming_parallelism to 4;

statement ok
drop table if exists t_rabbitmq_source;

statement ok
drop table if exists t_rabbitmq_multi_queue_source;

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py health

statement error prefetch_count must be between 1 and 1000
create table t_rabbitmq_zero_prefetch_count (
  id int,
  value varchar
) with (
  connector = 'rabbitmq',
  url = '${RABBITMQ_AMQP_URL}',
  queue = 'rw_slt_rabbitmq_queue',
  prefetch_count = '0'
) format plain encode json;

statement error prefetch_count must be between 1 and 1000
create table t_rabbitmq_invalid_prefetch_count (
  id int,
  value varchar
) with (
  connector = 'rabbitmq',
  url = '${RABBITMQ_AMQP_URL}',
  queue = 'rw_slt_rabbitmq_queue',
  prefetch_count = '1001'
) format plain encode json;

statement error prefetch_size=0
create table t_rabbitmq_invalid_prefetch_size (
  id int,
  value varchar
) with (
  connector = 'rabbitmq',
  url = '${RABBITMQ_AMQP_URL}',
  queue = 'rw_slt_rabbitmq_queue',
  prefetch_size = '1'
) format plain encode json;

statement error listed more than once
create table t_rabbitmq_duplicate_queue (
  id int,
  value varchar
) with (
  connector = 'rabbitmq',
  url = '${RABBITMQ_AMQP_URL}',
  queues = 'rw_slt_rabbitmq_queue,rw_slt_rabbitmq_queue'
) format plain encode json;

statement error queue.passive=true
create table t_rabbitmq_create_queue (
  id int,
  value varchar
) with (
  connector = 'rabbitmq',
  url = '${RABBITMQ_AMQP_URL}',
  queue = 'rw_slt_rabbitmq_queue',
  queue.passive = 'false'
) format plain encode json;

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py reset --exchange rw_slt_rabbitmq_exchange --queue rw_slt_rabbitmq_queue

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py setup --exchange rw_slt_rabbitmq_exchange --queue rw_slt_rabbitmq_queue --routing-key rw.slt.rabbitmq

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py publish-json --exchange rw_slt_rabbitmq_exchange --routing-key rw.slt.rabbitmq --count 100

statement ok
create table t_rabbitmq_source (
  id int,
  value varchar
) with (
  connector = 'rabbitmq',
  url = '${RABBITMQ_AMQP_URL}',
  queue = 'rw_slt_rabbitmq_queue',
  prefetch_count = '50',
  max_connections = '5',
  queue.passive = 'true'
) format plain encode json;

statement ok
flush;

query IIII retry 6 backoff 2s
select count(*), count(distinct id), min(id), max(id) from t_rabbitmq_source where id >= 0 and id < 100;
----
100 100 0 99

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_source where id < 0 or id >= 100;
----
0

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_source where id = 0 and value = 'message_0';
----
1

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_source where id = 50 and value = 'message_50';
----
1

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_source where id = 99 and value = 'message_99';
----
1

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py queue-stats --queue rw_slt_rabbitmq_queue --expect-ready 0 --expect-unacked 0 --timeout 30

statement ok
drop table t_rabbitmq_source;

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py reset --exchange rw_slt_rabbitmq_exchange --queue rw_slt_rabbitmq_queue

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py reset --exchange rw_slt_rabbitmq_exchange_multi_1 --queue rw_slt_rabbitmq_queue_multi_1

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py reset --exchange rw_slt_rabbitmq_exchange_multi_2 --queue rw_slt_rabbitmq_queue_multi_2

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py setup --exchange rw_slt_rabbitmq_exchange_multi_1 --queue rw_slt_rabbitmq_queue_multi_1 --routing-key rw.slt.rabbitmq.multi.1

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py setup --exchange rw_slt_rabbitmq_exchange_multi_2 --queue rw_slt_rabbitmq_queue_multi_2 --routing-key rw.slt.rabbitmq.multi.2

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py publish-json --exchange rw_slt_rabbitmq_exchange_multi_1 --routing-key rw.slt.rabbitmq.multi.1 --count 20

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py publish-json --exchange rw_slt_rabbitmq_exchange_multi_2 --routing-key rw.slt.rabbitmq.multi.2 --count 20 --start-id 1000

statement ok
create table t_rabbitmq_multi_queue_source (
  id int,
  value varchar
) with (
  connector = 'rabbitmq',
  url = '${RABBITMQ_AMQP_URL}',
  queues = 'rw_slt_rabbitmq_queue_multi_1,rw_slt_rabbitmq_queue_multi_2',
  prefetch_count = '20',
  max_connections = '5',
  queue.passive = 'true'
) format plain encode json;

statement ok
flush;

query IIII retry 6 backoff 2s
select count(*), count(distinct id), min(id), max(id) from t_rabbitmq_multi_queue_source where (id >= 0 and id < 20) or (id >= 1000 and id < 1020);
----
40 40 0 1019

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_multi_queue_source where (id >= 20 and id < 1000) or id < 0 or id >= 1020;
----
0

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_multi_queue_source where id = 0 and value = 'message_0';
----
1

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_multi_queue_source where id = 19 and value = 'message_19';
----
1

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_multi_queue_source where id = 1000 and value = 'message_1000';
----
1

query I retry 6 backoff 2s
select count(*) from t_rabbitmq_multi_queue_source where id = 1019 and value = 'message_1019';
----
1

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py queue-stats --queue rw_slt_rabbitmq_queue_multi_1 --expect-ready 0 --expect-unacked 0 --timeout 30

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py queue-stats --queue rw_slt_rabbitmq_queue_multi_2 --expect-ready 0 --expect-unacked 0 --timeout 30

statement ok
drop table t_rabbitmq_multi_queue_source;

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py reset --exchange rw_slt_rabbitmq_exchange_multi_1 --queue rw_slt_rabbitmq_queue_multi_1

system ok
python3 e2e_test/source_inline/rabbitmq/rabbitmq_operation.py reset --exchange rw_slt_rabbitmq_exchange_multi_2 --queue rw_slt_rabbitmq_queue_multi_2

statement ok
set streaming_use_shared_source to true;
