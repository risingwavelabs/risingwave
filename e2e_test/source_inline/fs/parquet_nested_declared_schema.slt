# A parquet file whose nested layout diverges from the declared schema must decode by the
# declared fields at every depth: struct children inside list elements / map values are
# aligned by name, extra file-side children are dropped, and missing ones read as NULL.
# Before the fix, decode below a list/map boundary followed the file-side layout, producing
# chunk columns whose type silently diverged from the catalog.
#
# The fixture is written by RisingWave's own fs parquet sink: the writer table's element
# struct <b, a, extra> is a reordered superset of the reader's declared element <a, b>, and
# the map value struct <y, x> is a reordered superset of the declared value <x>.

system ok
rm -rf /tmp/rw_parquet_nested_declared && mkdir -p /tmp/rw_parquet_nested_declared

statement ok
create table parquet_nested_writer (
    id int,
    l struct<b varchar, a int, extra int>[],
    m map(varchar, struct<y int, x int>)
) append only;

statement ok
insert into parquet_nested_writer values
    (1,
     array[row('x', 10, 9), row('y', 20, 8)]::struct<b varchar, a int, extra int>[],
     map {'k1': row(7, 42)::struct<y int, x int>, 'k2': row(6, 43)::struct<y int, x int>}),
    (2, null, null),
    (3,
     array[row(null, 30, 7)]::struct<b varchar, a int, extra int>[],
     map {'k3': row(5, null)::struct<y int, x int>});

statement ok
flush;

statement ok
create sink parquet_nested_sink from parquet_nested_writer
with (
    connector = 'fs',
    type = 'append-only',
    fs.path = '/tmp/rw_parquet_nested_declared',
    max_row_count = 1
) format plain encode parquet;

statement ok
create table parquet_nested_declared_schema (
    id int,
    l struct<a int, b varchar>[],
    m map(varchar, struct<x int>)
) with (
    connector = 'posix_fs',
    posix_fs.root = '/tmp/rw_parquet_nested_declared'
) format plain encode parquet;

# Wait until the sink has written all rows (each file is committed as soon as its row is
# written, `max_row_count = 1`) and the reader has discovered them; only then is it safe to
# drop the sink, and the value assertions below become deterministic.
query I retry 60 backoff 1s
select count(*) from parquet_nested_declared_schema;
----
3

statement ok
drop sink parquet_nested_sink;

query IITII
select
    id,
    (l[1]).a,
    (l[1]).b,
    (l[2]).a,
    (m['k1']).x
from parquet_nested_declared_schema order by id;
----
1 10 x 20 42
2 NULL NULL NULL NULL
3 30 NULL NULL NULL

query II
select (m['k2']).x, (m['k3']).x from parquet_nested_declared_schema where id in (1, 3) order by id;
----
43 NULL
NULL NULL

statement ok
drop table parquet_nested_declared_schema;

statement ok
drop table parquet_nested_writer;

system ok
rm -rf /tmp/rw_parquet_nested_declared
