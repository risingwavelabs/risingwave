# Regression test for reading Parquet TIME columns with all Arrow time units.
#
# The Parquet file below was generated with pyarrow 23.0.1:
#   id:   int32      = [1, 2]
#   t_s:  time32[s]  = [01:01:01, NULL]
#   t_ms: time32[ms] = [01:01:01.123, NULL]
#   t_us: time64[us] = [01:01:01.123456, NULL]
#   t_ns: time64[ns] = [01:01:01.123456789, NULL]

system ok
bash -euo pipefail -c '
  rm -rf /tmp/rw_parquet_time_units
  mkdir -p /tmp/rw_parquet_time_units
  printf "%s" "" \
    | base64 -d > /tmp/rw_parquet_time_units/data.parquet
'

statement ok
CREATE TABLE parquet_time_units (
    id int,
    t_s time,
    t_ms time,
    t_us time,
    t_ns time
) WITH (
    connector = 'posix_fs',
    posix_fs.root = '/tmp/rw_parquet_time_units'
) FORMAT PLAIN ENCODE PARQUET;

query ITTTT retry 20 backoff 1s
SELECT id, t_s, t_ms, t_us, t_ns FROM parquet_time_units ORDER BY id;
----
1 01:01:01 01:01:01.123 01:01:01.123456 01:01:01.123456789
2 NULL NULL NULL NULL

statement ok
DROP TABLE parquet_time_units;

system ok
rm -rf /tmp/rw_parquet_time_units
