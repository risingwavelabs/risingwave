control substitution on

statement ok
set streaming_use_shared_source to false;

statement ok
set streaming_parallelism to 2;

statement ok
create table t_rabbitmq_mqtt_pb (
  id int,
  value varchar
) with (
  connector = 'mqtt',
  url = 'mqtt://rabbitmq-server:1883',
  topic = 'test_topic_pb',
  qos = 'at_least_once'
) format plain encode protobuf (
  message = 'mqtt.TestRecord',
  schema.location = 'file:///risingwave/e2e_test/source_inline/mqtt/mqtt_simple.pb'
);

sleep 1s

# Produce initial messages
system ok
python3 e2e_test/source_inline/mqtt/rabbitmq_operation.py produce test_topic_pb 100 protobuf

sleep 3s

statement ok
flush;

query T retry 3 backoff 1s
select count(*) >= 100 from t_rabbitmq_mqtt_pb;
----
t

query T retry 3 backoff 1s
select count(*) > 0 from t_rabbitmq_mqtt_pb where id = 0 and value = 'message_0';
----
t

query T retry 3 backoff 1s
select count(*) > 0 from t_rabbitmq_mqtt_pb where id = 50 and value = 'message_50';
----
t

query T retry 3 backoff 1s
select count(*) > 0 from t_rabbitmq_mqtt_pb where id = 99 and value = 'message_99';
----
t

statement ok
drop table t_rabbitmq_mqtt_pb;

statement ok
set streaming_use_shared_source to true;
