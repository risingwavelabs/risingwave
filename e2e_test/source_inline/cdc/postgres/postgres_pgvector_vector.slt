control substitution on

# PostgreSQL pgvector CDC test: vector -> vector

statement ok
drop table if exists test_pgvector_cdc;

statement ok
drop source if exists pgvector_source;

system ok
psql -c "
    CREATE EXTENSION IF NOT EXISTS vector;
    DROP TABLE IF EXISTS test_pgvector_cdc CASCADE;
    CREATE TABLE test_pgvector_cdc (
        id int PRIMARY KEY,
        name varchar,
        embedding vector(3)
    );
    INSERT INTO test_pgvector_cdc VALUES
        (1, 'a', '[0.1,0.2,0.3]'),
        (2, 'b', '[1.1,1.2,1.3]');
"

statement ok
create source pgvector_source with (
  connector = 'postgres-cdc',
  hostname = '${PGHOST:localhost}',
  port = '${PGPORT:5432}',
  username = '${PGUSER:$USER}',
  password = '${PGPASSWORD:}',
  database.name = '${PGDATABASE:postgres}',
  schema.name = 'public',
  slot.name = 'pgvector_slot'
);

statement ok
create table test_pgvector_cdc (
    id int primary key,
    name varchar,
    embedding vector(3)
) from pgvector_source table 'public.test_pgvector_cdc';

# Mismatched vector dimension must be rejected at DDL validation time.
statement error Incompatible vector dimension
create table test_pgvector_cdc_dim_mismatch (
    id int primary key,
    name varchar,
    embedding vector(2)
) from pgvector_source table 'public.test_pgvector_cdc';

# Auto schema mapping should derive embedding as vector(3).
statement ok
create table test_pgvector_cdc_auto (*)
from pgvector_source table 'public.test_pgvector_cdc';

query T
select c.data_type
from rw_catalog.rw_columns c
join rw_catalog.rw_tables t on c.relation_id = t.id
where t.name = 'test_pgvector_cdc_auto' and c.name = 'embedding';
----
vector(3)

# Upstream vector without dimension should fail auto schema mapping.
system ok
psql -c "
    DROP TABLE IF EXISTS test_pgvector_nodim CASCADE;
    CREATE TABLE test_pgvector_nodim (
        id int PRIMARY KEY,
        embedding vector
    );
    INSERT INTO test_pgvector_nodim VALUES
        (1, '[0.1,0.2,0.3]');
"

statement error missing dimension
create table test_pgvector_nodim_auto (*)
from pgvector_source table 'public.test_pgvector_nodim';

# Auto schema change: add vector column in upstream PostgreSQL.
system ok
psql -c "
    DROP TABLE IF EXISTS test_pgvector_schema_change CASCADE;
    CREATE TABLE test_pgvector_schema_change (
        id int PRIMARY KEY,
        name varchar,
        embedding vector(3)
    );
    INSERT INTO test_pgvector_schema_change VALUES
        (1, 's1', '[0.1,0.2,0.3]');
"

statement ok
create source pgvector_schema_change_source with (
  connector = 'postgres-cdc',
  hostname = '${PGHOST:localhost}',
  port = '${PGPORT:5432}',
  username = '${PGUSER:$USER}',
  password = '${PGPASSWORD:}',
  database.name = '${PGDATABASE:postgres}',
  schema.name = 'public',
  slot.name = 'pgvector_schema_change_slot',
  auto.schema.change = 'true'
);

statement ok
create table test_pgvector_schema_change_rw (*)
from pgvector_schema_change_source table 'public.test_pgvector_schema_change';

query I retry 20 backoff 1s
select count(*) from test_pgvector_schema_change_rw;
----
1

system ok
psql -c "
    ALTER TABLE test_pgvector_schema_change ADD COLUMN embedding2 vector(3);
    INSERT INTO test_pgvector_schema_change VALUES
        (2, 's2', '[1.1,1.2,1.3]', '[9.1,9.2,9.3]');
"

query T retry 20 backoff 1s
select c.data_type
from rw_catalog.rw_columns c
join rw_catalog.rw_tables t on c.relation_id = t.id
where t.name = 'test_pgvector_schema_change_rw' and c.name = 'embedding2';
----
vector(3)

query ITT retry 20 backoff 1s
select id, name, embedding2::varchar
from test_pgvector_schema_change_rw
where id = 2;
----
2 s2 [9.1,9.2,9.3]

# Backfill should load 2 rows and keep embedding non-null.
query II retry 20 backoff 1s
select count(*), count(*) filter (where embedding is null) from test_pgvector_cdc;
----
2 0

# Compare upstream and RW vector text values for backfill rows.
query IIT retry 20 backoff 1s
select
  ours.id,
  ours.embedding::varchar = upstream.embedding_text as same_embedding,
  ours.embedding::varchar
from test_pgvector_cdc as ours
join (
  select * from postgres_query(
    '${PGHOST:localhost}',
    '${PGPORT:5432}',
    '${PGUSER:$USER}',
    '${PGPASSWORD:}',
    '${PGDATABASE:postgres}',
    'select id, embedding::text as embedding_text from test_pgvector_cdc where id in (1,2) order by id'
  )
) as upstream(id, embedding_text)
on ours.id = upstream.id
order by ours.id;
----
1 t [0.1,0.2,0.3]
2 t [1.1,1.2,1.3]

# Incremental UPDATE + INSERT + DELETE
system ok
psql -c "
    UPDATE test_pgvector_cdc SET embedding='[9.1,9.2,9.3]', name='a2' WHERE id=1;
    INSERT INTO test_pgvector_cdc VALUES (3, 'c', '[2.1,2.2,2.3]');
    DELETE FROM test_pgvector_cdc WHERE id=2;
"

# Final row count and null check.
query II retry 20 backoff 1s
select count(*), count(*) filter (where embedding is null) from test_pgvector_cdc;
----
2 0

# Final content check.
query ITT retry 20 backoff 1s
select id, name, embedding::varchar from test_pgvector_cdc order by id;
----
1 a2 [9.1,9.2,9.3]
3 c [2.1,2.2,2.3]

# Compare final upstream and RW values.
query IIT retry 20 backoff 1s
select
  ours.id,
  ours.embedding::varchar = upstream.embedding_text as same_embedding,
  ours.embedding::varchar
from test_pgvector_cdc as ours
join (
  select * from postgres_query(
    '${PGHOST:localhost}',
    '${PGPORT:5432}',
    '${PGUSER:$USER}',
    '${PGPASSWORD:}',
    '${PGDATABASE:postgres}',
    'select id, embedding::text as embedding_text from test_pgvector_cdc order by id'
  )
) as upstream(id, embedding_text)
on ours.id = upstream.id
order by ours.id;
----
1 t [9.1,9.2,9.3]
3 t [2.1,2.2,2.3]

statement ok
drop table test_pgvector_cdc;

statement ok
drop table test_pgvector_cdc_auto;

statement ok
drop source pgvector_source;

statement ok
drop table test_pgvector_schema_change_rw;

statement ok
drop source pgvector_schema_change_source;

system ok
psql -c "
    DROP TABLE IF EXISTS test_pgvector_cdc CASCADE;
    DROP TABLE IF EXISTS test_pgvector_nodim CASCADE;
    DROP TABLE IF EXISTS test_pgvector_schema_change CASCADE;
"
