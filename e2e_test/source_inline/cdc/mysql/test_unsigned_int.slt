# Test MySQL CDC with UNSIGNED BIGINT handling
# This test verifies that UNSIGNED BIGINT values are handled correctly in CDC backfill
# with debezium.bigint.unsigned.handling.mode='precise'

control substitution on

system ok
mysql -e "
    CREATE DATABASE IF NOT EXISTS risedev;
    USE risedev;
    DROP TABLE IF EXISTS test_unsigned_int;
    CREATE TABLE test_unsigned_int (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        unsigned_bigint BIGINT UNSIGNED NOT NULL DEFAULT '0',
        unsigned_int INT UNSIGNED NOT NULL DEFAULT '0',
        unsigned_smallint SMALLINT UNSIGNED NOT NULL DEFAULT '0',
        unsigned_tinyint TINYINT UNSIGNED NOT NULL DEFAULT '0',
        info VARCHAR(50) NOT NULL DEFAULT '',
        PRIMARY KEY (id, unsigned_bigint)
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
"

# Insert 50 backfill rows into MySQL (20 non-overflow + 30 overflow)
system ok
mysql -e "
    USE risedev;
    INSERT INTO test_unsigned_int (unsigned_bigint, unsigned_int, unsigned_smallint, unsigned_tinyint, info) VALUES
        (1, 1, 1, 1, 'backfill'),
        (12345, 12345, 12345, 123, 'backfill'),
        (123456, 123456, 12345, 123, 'backfill'),
        (1234567, 1234567, 12345, 123, 'backfill'),
        (12345678, 12345678, 12345, 123, 'backfill'),
        (123456789, 123456789, 12345, 123, 'backfill'),
        (1234567890, 1234567890, 12345, 123, 'backfill'),
        (12345678901, 1234567890, 12345, 123, 'backfill'),
        (123456789012, 1234567890, 12345, 123, 'backfill'),
        (1234567890123, 1234567890, 12345, 123, 'backfill'),
        (12345678901234, 1234567890, 12345, 123, 'backfill'),
        (123456789012345, 1234567890, 12345, 123, 'backfill'),
        (1234567890123456, 1234567890, 12345, 123, 'backfill'),
        (12345678901234567, 1234567890, 12345, 123, 'backfill'),
        (123456789012345678, 1234567890, 12345, 123, 'backfill'),
        (1234567890123456789, 1234567890, 12345, 123, 'backfill'),
        (12345678901234567890, 1234567890, 12345, 123, 'backfill'),
        (9223372036854775800, 2147483647, 65535, 255, 'backfill'),
        (9223372036854775805, 2147483647, 65535, 255, 'backfill'),
        (9223372036854775807, 2147483647, 65535, 255, 'backfill');
    INSERT INTO test_unsigned_int (unsigned_bigint, unsigned_int, unsigned_smallint, unsigned_tinyint, info) VALUES
        (9223372036854775808, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775809, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775810, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775811, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775812, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775813, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775814, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775815, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775816, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775817, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775818, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775819, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775820, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775821, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775822, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775823, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775824, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775825, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775826, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775827, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775828, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775829, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775830, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775831, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775832, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775833, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775834, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775835, 4294967295, 65535, 255, 'backfill'),
        (9223372036854775836, 4294967295, 65535, 255, 'backfill'),
        (18446251075179777772, 4294967295, 65535, 255, 'backfill');
"

sleep 2s

statement ok
create source s_unsigned_int_upcast with (
  ${RISEDEV_MYSQL_WITH_OPTIONS_COMMON},
  username = '${RISEDEV_MYSQL_USER}',
  password = '${MYSQL_PWD}',
  database.name = 'risedev',
  debezium.bigint.unsigned.handling.mode = 'precise'
);

statement ok
create source s_unsigned_int_to_signed with (
  ${RISEDEV_MYSQL_WITH_OPTIONS_COMMON},
  username = '${RISEDEV_MYSQL_USER}',
  password = '${MYSQL_PWD}',
  database.name = 'risedev'
);

sleep 2s

statement ok
create table rw_unsigned_int_upcast (
  id DECIMAL,
  unsigned_bigint DECIMAL,
  unsigned_int BIGINT,
  unsigned_smallint INT,
  unsigned_tinyint SMALLINT,
  info VARCHAR,
  primary key (id, unsigned_bigint)
) with (
  snapshot = 'true',
  snapshot.batch_size = 10,
) from s_unsigned_int_upcast table 'risedev.test_unsigned_int';

statement ok
create table rw_unsigned_int_to_signed (
  id bigint,
  unsigned_bigint bigint,
  info VARCHAR,
  primary key (id, unsigned_bigint)
) with (
  snapshot = 'true',
  snapshot.batch_size = 10,
) from s_unsigned_int_to_signed table 'risedev.test_unsigned_int';

sleep 5s

# Insert 3 incremental data (debezium)
system ok
mysql -e "
    USE risedev;
    INSERT INTO test_unsigned_int (unsigned_bigint, unsigned_int, unsigned_smallint, unsigned_tinyint, info) VALUES
        (18446251075179777770, 4294967295, 65535, 255, 'debezium'),
        (18446251075179777771, 4294967295, 65535, 255, 'debezium'),
        (18446251075179777772, 4294967295, 65535, 255, 'debezium');
"


# Verify total count in RisingWave (50 backfill + 3 debezium = 53)
query I retry 4 backoff 1s
select count(*) as row_cnt from rw_unsigned_int_upcast;
----
53

query I
select count(*) as row_cnt from rw_unsigned_int_to_signed;
----
53

# Verify we have both backfill and debezium data
query T
select count(*) as backfill_count from rw_unsigned_int_upcast where info = 'backfill';
----
50

query T
select count(*) as backfill_count from rw_unsigned_int_to_signed where info = 'backfill';
----
50

query T
select count(*) as debezium_count from rw_unsigned_int_upcast where info = 'debezium';
----
3

query T
select count(*) as debezium_count from rw_unsigned_int_to_signed where info = 'debezium';
----
3

# Verify specific rows match inserted data
# Check id=50 for upcast table(last backfill row with overflow data)
query TTTTTT
select id, unsigned_bigint, unsigned_int, unsigned_smallint, unsigned_tinyint, info from rw_unsigned_int_upcast where id = 50;
----
50	18446251075179777772	4294967295	65535	255	backfill

# Check id=50 for (unsigned bigint->bigint) table
query TTTTTT
select id, unsigned_bigint, info from rw_unsigned_int_to_signed where id = 50;
----
50	-492998529773844	backfill

# Check id=53 (last debezium row with overflow data)
query TTTTTT
select id, unsigned_bigint, unsigned_int, unsigned_smallint, unsigned_tinyint, info from rw_unsigned_int_upcast where id = 53;
----
53	18446251075179777772	4294967295	65535	255	debezium

# Check id=53 for unsigned bigint -> bigint table
query TTTTTT
select id, unsigned_bigint, info from rw_unsigned_int_to_signed where id = 53;
----
53	-492998529773844	debezium

# Test schema check: unsigned int -> int32 should fail
statement error Incompatible data type of column unsigned_int. MySQL type: int unsigned, RisingWave type: INT32
create table rw_unsigned_int_to_int32 (
  id DECIMAL,
  unsigned_bigint BIGINT,
  unsigned_int INT,
  unsigned_tinyint SMALLINT,
  info VARCHAR,
  primary key (id, unsigned_bigint)
) with (
  snapshot = 'true',
  snapshot.batch_size = 10,
) from s_unsigned_int_to_signed table 'risedev.test_unsigned_int';

# Test schema check: unsigned smallint -> smallint should fail
statement error Incompatible data type of column unsigned_smallint. MySQL type: smallint unsigned, RisingWave type: INT16
create table rw_unsigned_smallint_to_smallint (
  id DECIMAL,
  unsigned_bigint BIGINT,
  unsigned_smallint SMALLINT,
  unsigned_tinyint SMALLINT,
  info VARCHAR,
  primary key (id, unsigned_bigint)
) with (
  snapshot = 'true',
  snapshot.batch_size = 10,
) from s_unsigned_int_to_signed table 'risedev.test_unsigned_int';

# Regression: buffered binlog rows must be compared with MySQL unsigned ordering.
#
# The initial table only contains BIGINT UNSIGNED values that overflow RW BIGINT and become
# negative i64 values. After backfill has advanced into that range, insert a non-overflow PK.
# The row is already behind the snapshot cursor in MySQL unsigned order, so it must be emitted
# from the binlog buffer instead of being filtered out by signed i64 comparison.
system ok
mysql -e "
    USE risedev;
    DROP TABLE IF EXISTS test_unsigned_bigint_backfill_buffer;
    CREATE TABLE test_unsigned_bigint_backfill_buffer (
        id BIGINT UNSIGNED NOT NULL,
        info VARCHAR(50) NOT NULL DEFAULT '',
        PRIMARY KEY (id)
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
"

system ok
mysql -e "
    USE risedev;
    INSERT INTO test_unsigned_bigint_backfill_buffer (id, info)
    SELECT 9223372036854775808 + ones.n + tens.n * 10 + hundreds.n * 100, 'backfill'
    FROM
        (SELECT 0 AS n UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4
         UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 UNION ALL SELECT 9) ones
    CROSS JOIN
        (SELECT 0 AS n UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4
         UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 UNION ALL SELECT 9) tens
    CROSS JOIN
        (SELECT 0 AS n UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4
         UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 UNION ALL SELECT 9) hundreds;
"

statement ok
set backfill_rate_limit=1;

statement ok
create table rw_unsigned_bigint_backfill_buffer (
  id BIGINT,
  info VARCHAR,
  primary key (id)
) with (
  snapshot = 'true',
  snapshot.batch_size = 10,
) from s_unsigned_int_to_signed table 'risedev.test_unsigned_bigint_backfill_buffer';

query B retry 30 backoff 1s
select count(*) > 0 and count(*) < 1000 from rw_unsigned_bigint_backfill_buffer;
----
true

system ok
mysql -e "
    USE risedev;
    INSERT INTO test_unsigned_bigint_backfill_buffer VALUES (42, 'buffer');
"

statement ok
ALTER TABLE rw_unsigned_bigint_backfill_buffer SET backfill_rate_limit = 1000;

query I retry 30 backoff 1s
select count(*) from rw_unsigned_bigint_backfill_buffer where id = 42 and info = 'buffer';
----
1

query I retry 30 backoff 1s
select count(*) from rw_unsigned_bigint_backfill_buffer;
----
1001


# Clean up
statement ok
drop table rw_unsigned_bigint_backfill_buffer;

statement ok
drop table rw_unsigned_int_upcast;

statement ok
drop table rw_unsigned_int_to_signed;

statement ok
drop source s_unsigned_int_upcast cascade;

statement ok
drop source s_unsigned_int_to_signed cascade;

system ok
mysql -e "
    USE risedev;
    DROP TABLE IF EXISTS test_unsigned_int;
    DROP TABLE IF EXISTS test_unsigned_bigint_backfill_buffer;
"
