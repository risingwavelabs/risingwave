control substitution on

system ok
mysql -e "
    DROP DATABASE IF EXISTS testdb_direct_cdc_inject_offset;
    CREATE DATABASE testdb_direct_cdc_inject_offset;
    USE testdb_direct_cdc_inject_offset;
    CREATE TABLE t_inject_offset (
        id INT PRIMARY KEY,
        payload VARCHAR(64)
    );
    INSERT INTO t_inject_offset VALUES
        (1, 'row-1'),
        (2, 'row-2'),
        (3, 'row-3');
"

system ok
mysql -e "
    DROP USER IF EXISTS 'non-shared-cdc'@'%';
    CREATE USER 'non-shared-cdc'@'%' IDENTIFIED BY '123456';
    GRANT SELECT, RELOAD, SHOW DATABASES, REPLICATION SLAVE, REPLICATION CLIENT ON *.* TO 'non-shared-cdc'@'%';
    FLUSH PRIVILEGES;
"

statement ok
create table direct_cdc_inject_offset (
    id INT PRIMARY KEY,
    payload VARCHAR
) with (
    ${RISEDEV_MYSQL_WITH_OPTIONS_COMMON},
    username = 'non-shared-cdc',
    password = '123456',
    database.name = 'testdb_direct_cdc_inject_offset',
    table.name = 't_inject_offset'
);

query I retry 20 backoff 1s
select count(*) from direct_cdc_inject_offset;
----
3

system ok
mysql -e "
    INSERT INTO testdb_direct_cdc_inject_offset.t_inject_offset VALUES
        (4, 'row-4');
"

query I retry 20 backoff 1s
select count(*) from direct_cdc_inject_offset;
----
4

system ok
psql -h ${RISEDEV_RW_FRONTEND_LISTEN_ADDRESS} \
    -p ${RISEDEV_RW_FRONTEND_PORT} \
    -d $__DATABASE__ \
    -U root \
    -t -A \
    -c "SELECT id
        FROM rw_sources
        WHERE associated_table_id = (SELECT id FROM rw_tables WHERE name = 'direct_cdc_inject_offset')
        ORDER BY id
        LIMIT 1;" > /tmp/direct_cdc_source_id.txt

system ok
python3 e2e_test/source_inline/cdc/mysql/cron_only/capture_mysql_master_status.py \
    --file-output /tmp/direct_cdc_binlog_file_before.txt \
    --pos-output /tmp/direct_cdc_binlog_pos_before.txt \
    --file-seq-output /tmp/direct_cdc_binlog_file_seq_before.txt
system ok
python3 e2e_test/source_inline/cdc/mysql/cron_only/build_mysql_inject_offsets.py \
    --split-id "$(cat /tmp/direct_cdc_source_id.txt)" \
    --binlog-file "$(cat /tmp/direct_cdc_binlog_file_before.txt)" \
    --binlog-pos "$(cat /tmp/direct_cdc_binlog_pos_before.txt)" \
    --output /tmp/direct_cdc_offsets_before.json

system ok
mysql -e "
    INSERT INTO testdb_direct_cdc_inject_offset.t_inject_offset VALUES
        (5, 'row-5'),
        (6, 'row-6');
"

query I retry 20 backoff 1s
select count(*) from direct_cdc_inject_offset;
----
6

system ok
python3 e2e_test/source_inline/cdc/mysql/cron_only/wait_mysql_cdc_metrics.py \
    --source-id "$(cat /tmp/direct_cdc_source_id.txt)" \
    --file-seq "$(cat /tmp/direct_cdc_binlog_file_seq_before.txt)" \
    --pos "$(cat /tmp/direct_cdc_binlog_pos_before.txt)" \
    --mode advance

statement ok
alter table direct_cdc_inject_offset set source_rate_limit to 0;

system ok
SOURCE_ID=$(cat /tmp/direct_cdc_source_id.txt) && \
OFFSETS=$(cat /tmp/direct_cdc_offsets_before.json) && \
./risedev ctl meta inject-source-offsets \
    --source-id "$SOURCE_ID" \
    --offsets "$OFFSETS"

system ok
python3 e2e_test/source_inline/cdc/mysql/cron_only/wait_mysql_cdc_metrics.py \
    --source-id "$(cat /tmp/direct_cdc_source_id.txt)" \
    --file-seq "$(cat /tmp/direct_cdc_binlog_file_seq_before.txt)" \
    --pos "$(cat /tmp/direct_cdc_binlog_pos_before.txt)" \
    --mode equal

statement ok
alter table direct_cdc_inject_offset set source_rate_limit to default;

system ok
mysql -e "
    INSERT INTO testdb_direct_cdc_inject_offset.t_inject_offset VALUES
        (7, 'row-7');
"

system ok
python3 e2e_test/source_inline/cdc/mysql/cron_only/capture_mysql_master_status.py \
    --file-output /tmp/direct_cdc_binlog_file_after_resume.txt \
    --pos-output /tmp/direct_cdc_binlog_pos_after_resume.txt \
    --file-seq-output /tmp/direct_cdc_binlog_file_seq_after_resume.txt

system ok
python3 e2e_test/source_inline/cdc/mysql/cron_only/wait_mysql_cdc_metrics.py \
    --source-id "$(cat /tmp/direct_cdc_source_id.txt)" \
    --file-seq "$(cat /tmp/direct_cdc_binlog_file_seq_after_resume.txt)" \
    --pos "$(cat /tmp/direct_cdc_binlog_pos_after_resume.txt)" \
    --mode at_least
query I retry 20 backoff 1s
select count(*) from direct_cdc_inject_offset;
----
7

statement ok
drop table direct_cdc_inject_offset;

system ok
mysql -e "DROP DATABASE IF EXISTS testdb_direct_cdc_inject_offset;"
