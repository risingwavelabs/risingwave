"

system ok
bash -ceu '
source /Users/tab/conductor/workspaces/risingwave/madrid/.risingwave/config/risedev-env
for _ in $(seq 1 180); do
    ACTUAL=$(psql -h "$RISEDEV_RW_FRONTEND_LISTEN_ADDRESS" \
        -p "$RISEDEV_RW_FRONTEND_PORT" \
        -d "$__DATABASE__" \
        -U root \
        -t -A \
        -c "SELECT string_agg(id || '':' || payload, '','' ORDER BY id) FROM direct_cdc_inject_offset" 2>/dev/null || true)
    if [ "$ACTUAL" = "1:row-1,2:row-2,3:row-3,4:row-4-before-inject,5:row-5-after-inject" ]; then
        exit 0
    fi
    sleep 1
done
echo "timed out waiting for injected direct CDC rows" >&2
exit 1
'

