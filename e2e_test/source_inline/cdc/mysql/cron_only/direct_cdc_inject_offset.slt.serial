system ok
psql -h ${RISEDEV_RW_FRONTEND_LISTEN_ADDRESS} \
    -p ${RISEDEV_RW_FRONTEND_PORT} \
    -d $__DATABASE__ \
    -U root \
    -t -A \
    -c "SELECT id
        FROM rw_sources
        WHERE associated_table_id = (SELECT id FROM rw_tables WHERE name = 'direct_cdc_inject_offset')
        ORDER BY id DESC
        LIMIT 1;" > /tmp/direct_cdc_source_id.txt

system ok
bash -ceu '
source /Users/tab/conductor/workspaces/risingwave/madrid/.risingwave/config/risedev-env
STATE_TABLE=$(psql -h "$RISEDEV_RW_FRONTEND_LISTEN_ADDRESS" \
    -p "$RISEDEV_RW_FRONTEND_PORT" \
    -d "$__DATABASE__" \
    -U root \
    -t -A \
    -c "SELECT name
        FROM rw_catalog.rw_internal_table_info
        WHERE job_name = '\''direct_cdc_inject_offset'\''
          AND job_type = '\''table'\''
        ORDER BY job_id DESC
        LIMIT 1;")
SOURCE_ID=$(cat /tmp/direct_cdc_source_id.txt)
for _ in $(seq 1 60); do
    OFFSET=$(psql -h "$RISEDEV_RW_FRONTEND_LISTEN_ADDRESS" \
        -p "$RISEDEV_RW_FRONTEND_PORT" \
        -d "$__DATABASE__" \
        -U root \
        -t -A \
        -c "SELECT offset_info->'\''split_info'\''->'\''mysql_split'\''->'\''inner'\''->>'\''start_offset'\''
            FROM ${STATE_TABLE}
            WHERE partition_id = '\''${SOURCE_ID}'\''
            LIMIT 1;")
    if [ -n "$OFFSET" ] && printf '%s' "$OFFSET" | grep -q '"isHeartbeat":false'; then
        printf '%s' "$OFFSET" > /tmp/direct_cdc_current_offset.txt
        exit 0
    fi
    sleep 1
done
echo "timed out waiting for non-heartbeat direct CDC offset" >&2
exit 1
'

system ok
python3 -c "import json, pathlib; source_id = pathlib.Path('/tmp/direct_cdc_source_id.txt').read_text().strip(); offset = pathlib.Path('/tmp/direct_cdc_current_offset.txt').read_text().strip(); pathlib.Path('/tmp/direct_cdc_offsets.json').write_text(json.dumps({source_id: offset}, separators=(',', ':'), sort_keys=True))"

system ok
bash -ceu '
source /Users/tab/conductor/workspaces/risingwave/madrid/.risingwave/config/risedev-env
SOURCE_ID="$(cat /tmp/direct_cdc_source_id.txt)"
OFFSETS="$(cat /tmp/direct_cdc_offsets.json)"
for _ in $(seq 1 30); do
    if /Users/tab/conductor/workspaces/risingwave/madrid/.risingwave/bin/risingwave/risectl meta inject-source-offsets \
        --source-id "$SOURCE_ID" \
        --offsets "$OFFSETS"; then
        exit 0
    fi
    sleep 1
done
exit 1
'

