4 9999-12-31 23:59:59.999 23:59:59.900 23:59:59.999 23:59:59.999 NULL NULL 9999-12-31 23:59:59.999 9999-12-31 23:59:59.999 9999-12-31 23:59:59.999 9999-12-31 23:59:59.999+00:00
