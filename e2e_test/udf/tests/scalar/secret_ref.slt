# Test: secret references as function call arguments (ExprImpl::SecretRef)
# Secrets resolve to Varchar at runtime via LocalSecretManager.
# Works uniformly with external UDFs, SQL UDFs, and built-in functions.

# ============================================================
# Setup
# ============================================================

statement ok
CREATE SECRET test_secret WITH (backend = 'meta') AS 'hello_secret';

statement ok
CREATE SECRET another_secret WITH (backend = 'meta') AS 'world';

statement ok
CREATE FUNCTION echo_with_secret(data varchar, key varchar) RETURNS VARCHAR LANGUAGE python AS $$
def echo_with_secret(data, key):
    return data + ':' + key
$$;

# ============================================================
# Basic functionality
# ============================================================

# 1. Secret in external UDF
query T
SELECT echo_with_secret('data', secret test_secret);
----
data:hello_secret

# 2. Secret in built-in function
query T
SELECT concat('prefix:', secret test_secret);
----
prefix:hello_secret

# 3. Secret in SQL UDF (inline expansion)
statement ok
CREATE FUNCTION sql_echo(a varchar, b varchar) RETURNS varchar LANGUAGE sql AS 'select a || b';

query T
SELECT sql_echo('sql:', secret test_secret);
----
sql:hello_secret

# ============================================================
# Multiple secrets and edge cases
# ============================================================

# 4. Multiple secrets in one call
query T
SELECT concat(secret test_secret, ':', secret another_secret);
----
hello_secret:world

# 5. Secret as the only argument
query T
SELECT upper(secret test_secret);
----
HELLO_SECRET

# 6. Secret in nested function call
query T
SELECT concat('nested:', upper(secret test_secret));
----
nested:HELLO_SECRET

# 7. Secret in CASE WHEN
query T
SELECT CASE WHEN length(secret test_secret) > 0 THEN 'has_value' ELSE 'empty' END;
----
has_value

# 8. Secret in subquery
query T
SELECT * FROM (SELECT concat('sub:', secret test_secret) AS val);
----
sub:hello_secret

# 9. Secret with table data
statement ok
CREATE TABLE t1 (data varchar);

statement ok
INSERT INTO t1 VALUES ('row1'), ('row2');

statement ok
FLUSH;

query T rowsort
SELECT echo_with_secret(data, secret test_secret) FROM t1;
----
row1:hello_secret
row2:hello_secret

# 10. Secret in WHERE clause
query T
SELECT data FROM t1 WHERE concat(data, secret test_secret) = 'row1hello_secret';
----
row1

# ============================================================
# Error cases
# ============================================================

# 11. Non-existent secret
statement error not found
SELECT concat('a', secret nonexistent_secret);

# 12. Secret outside function call (should be parse error — 'secret' treated as identifier)
# SELECT secret test_secret;  -- this is a parse error, not testable via SLT

# ============================================================
# Dependency tracking
# ============================================================

# 13. DROP SECRET blocked when MV references it
statement ok
CREATE MATERIALIZED VIEW mv1 AS SELECT echo_with_secret(data, secret test_secret) FROM t1;

statement error
DROP SECRET test_secret;

# 14. DROP SECRET succeeds after MV dropped
statement ok
DROP MATERIALIZED VIEW mv1;

# 15. DROP SECRET blocked when another MV uses it in built-in function
statement ok
CREATE MATERIALIZED VIEW mv2 AS SELECT concat(data, secret test_secret) FROM t1;

statement error
DROP SECRET test_secret;

statement ok
DROP MATERIALIZED VIEW mv2;

# 16. Secret in SQL UDF within MV
statement ok
CREATE MATERIALIZED VIEW mv3 AS SELECT sql_echo(data, secret test_secret) FROM t1;

statement error
DROP SECRET test_secret;

statement ok
DROP MATERIALIZED VIEW mv3;

# ============================================================
# Cleanup
# ============================================================

statement ok
DROP TABLE t1;

statement ok
DROP SECRET test_secret;

statement ok
DROP SECRET another_secret;

statement ok
DROP FUNCTION echo_with_secret;

statement ok
DROP FUNCTION sql_echo;
