# Test: secret references as UDF function call arguments
# Verifies: secret resolution, error cases, and dependency tracking
#
# Contract: secrets resolve to Varchar values. UDF args that receive
# secrets must be Varchar or Bytea. Incompatible types cause UDF lookup
# failure (the placeholder Varchar won't match the function signature).

# Setup secrets
statement ok
CREATE SECRET test_secret WITH (backend = 'meta') AS 'hello_secret';

# Setup UDF
statement ok
CREATE FUNCTION echo_with_secret(data varchar, key varchar) RETURNS VARCHAR LANGUAGE python AS $$
def echo_with_secret(data, key):
    return data + ':' + key
$$;

# 1. Basic: secret resolved and passed to UDF
query T
SELECT echo_with_secret('data', secret test_secret);
----
data:hello_secret

# 2. Error: secret ref in non-UDF (built-in) function
statement error secret references are only supported in user-defined function arguments
SELECT concat('a', secret test_secret);

# 3. Error: secret ref in SQL UDF
statement ok
CREATE FUNCTION sql_udf(a varchar, b varchar) RETURNS varchar LANGUAGE sql AS 'select a || b';

statement error secret references are not supported in SQL user-defined functions
SELECT sql_udf('a', secret test_secret);

# 4. Error: secret ref in window function
statement ok
CREATE TABLE wt (v varchar);

statement error secret references are only supported in scalar user-defined function calls
SELECT echo_with_secret(v, secret test_secret) OVER () FROM wt;

statement ok
DROP TABLE wt;

# 5. Dependency: DROP SECRET blocked when MV references it
statement ok
CREATE TABLE t1 (data varchar);

statement ok
CREATE MATERIALIZED VIEW mv1 AS SELECT echo_with_secret(data, secret test_secret) FROM t1;

statement error
DROP SECRET test_secret;

# 6. Dependency: DROP succeeds after MV dropped
statement ok
DROP MATERIALIZED VIEW mv1;

statement ok
DROP TABLE t1;

statement ok
DROP SECRET test_secret;

# Cleanup
statement ok
DROP FUNCTION echo_with_secret;

statement ok
DROP FUNCTION sql_udf;
