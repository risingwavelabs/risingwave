control substitution on

# `onlyif` is sqllogictest conditional syntax.
# This file is executed by `ci/scripts/e2e-source-test.sh` with `--label kafka`.
onlyif kafka
statement ok
set rw_implicit_flush to true;

onlyif kafka
statement ok
set streaming_use_shared_source to true;

onlyif kafka
system ok
rpk topic delete streaming_parallelism_source -X brokers=${RISEDEV_KAFKA_BOOTSTRAP_SERVERS} || true

onlyif kafka
system ok
rpk topic create streaming_parallelism_source -p 32 -X brokers=${RISEDEV_KAFKA_BOOTSTRAP_SERVERS}

# Case: global=default, streaming_parallelism_for_source=default
onlyif kafka
statement ok
set streaming_parallelism to default;

onlyif kafka
statement ok
set streaming_parallelism_for_source to default;

onlyif kafka
statement ok
create source s_dd (v int) with (
    connector = 'kafka',
    properties.bootstrap.server = '${RISEDEV_KAFKA_BOOTSTRAP_SERVERS}',
    topic = 'streaming_parallelism_source',
    scan.startup.mode = 'earliest'
) format plain encode json;

onlyif kafka
query TT
select connector, is_shared from rw_sources where name = 's_dd';
----
KAFKA	t

onlyif kafka
query T
select parallelism from rw_streaming_parallelism where name = 's_dd';
----
bounded(4)

onlyif kafka
statement ok
drop source s_dd;

# Case: global=default, streaming_parallelism_for_source=6
onlyif kafka
statement ok
