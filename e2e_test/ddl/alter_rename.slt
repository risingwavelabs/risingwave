query TT rowsort
SELECT relation_type, name
FROM rw_relations
WHERE name IN (
    't',
    'schema_target',
    'schema_source',
    'schema_mv',
    'schema_view',
    'schema_index',
    'schema_sink',
    'schema_into_sink',
    'schema_subscription'
)
  AND position('schema1.' IN definition) > 0
  AND position('schema.' IN definition) = 0;
----
index schema_index
materialized view schema_mv
sink schema_into_sink
sink schema_sink
source schema_source
subscription schema_subscription
table schema_target
table t
view schema_view

query T
SELECT definition FROM rw_indexes WHERE name = 'schema_index';
----
CREATE INDEX schema_index ON schema1.t(id)

