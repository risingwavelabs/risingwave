control substitution on

statement ok
create table internal_sink_t (v1 int);

statement ok
create materialized view internal_sink_source as select * from internal_sink_t;

let internal_streamscan_table
SELECT name
FROM rw_catalog.rw_internal_table_info
WHERE job_name = 'internal_sink_source'
  AND name LIKE '%streamscan%'
ORDER BY id
LIMIT 1

statement error CREATE SINK does not support internal table
create sink internal_sink_target as
select * from ${internal_streamscan_table}
with (connector = 'blackhole');

statement ok
drop materialized view internal_sink_source;

statement ok
drop table internal_sink_t;
