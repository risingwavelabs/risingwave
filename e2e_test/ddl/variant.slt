# VARIANT must be rejected from storage keys: table pk, index keys, and MV ORDER BY.

statement error is part of the storage primary key
create table variant_pk_t (v variant primary key);

statement error is part of the storage primary key
create table variant_nested_pk_t (s struct<v variant> primary key);

statement ok
create table variant_key_source_t (id int primary key, payload variant);

statement error is part of the storage primary key
create index variant_idx on variant_key_source_t (payload);

statement error is part of the storage primary key
create materialized view variant_order_mv as
select payload from variant_key_source_t order by payload;

statement ok
drop table variant_key_source_t;

# VARIANT columns are rejected for row encodings without variant parser support.

statement error is not supported for this source encoding yet
create table variant_json_encode_t (id int, payload variant)
with (
    connector = 'posix_fs',
    posix_fs.root = '/tmp',
    match_pattern = '*.json'
) format plain encode json;

# Nested VARIANT is rejected too.

statement error is not supported for this source encoding yet
create table variant_json_encode_arr_t (id int, payloads variant[])
with (
    connector = 'posix_fs',
    posix_fs.root = '/tmp',
    match_pattern = '*.json'
) format plain encode json;

statement error is not supported for this source encoding yet
