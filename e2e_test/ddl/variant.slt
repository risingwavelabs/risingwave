statement ok
create table variant_table_definition (
    id int primary key,
    payload variant,
    payloads variant[]
);

query TTTTTT
select
    variant_typeof(parse_variant('1')),
    variant_typeof(parse_variant('1.5')),
    variant_typeof(to_variant(1::int4)),
    variant_typeof(to_variant(1::int8)),
    variant_typeof(to_variant(1.0::decimal)),
    variant_typeof(to_variant(1.0::double precision));
----
int64 double int32 int64 decimal16 double

statement ok
create table variant_full_type_t (
    b boolean,
    i2 smallint,
    i4 integer,
    i8 bigint,
    f4 real,
    f8 double precision,
    dec decimal,
    str varchar,
    bin bytea,
    d date,
    tm time,
    ts timestamp,
    tstz timestamptz,
    js jsonb,
    arr integer[],
    st struct<a int, b varchar>,
    mp map(varchar, int)
);

statement ok
insert into variant_full_type_t values (
    true,
    1::smallint,
    1::integer,
    1::bigint,
    1.5::real,
    1.5::double precision,
    123.45::decimal,
    'hello',
    '\x1234'::bytea,
    date '2024-01-02',
    time '03:04:05.006',
    timestamp '2024-01-02 03:04:05.006',
    '2024-01-02 03:04:05.006+00:00'::timestamptz,
    '{"a":1}'::jsonb,
    array[1, 2]::integer[],
    row(1, 'a'),
    map{'k': 1}
);

statement ok
flush

query TT rowsort
with typed as (
    select _row_id, * from variant_full_type_t
), variants(input_type, value) as (
    values
        ('sql_null', to_variant(null::integer)),
        ('parse_json_null', parse_variant('null')),
        ('parse_json_boolean', parse_variant('true')),
        ('parse_json_integer', parse_variant('1')),
        ('parse_json_float', parse_variant('1.5')),
        ('parse_json_string', parse_variant('"hello"')),
        ('parse_json_array', parse_variant('[1,2]')),
        ('parse_json_object', parse_variant('{"a":1}'))
    union all
    select 'boolean', to_variant(b) from typed
    union all
    select 'int2', to_variant(i2) from typed
    union all
    select 'int4', to_variant(i4) from typed
    union all
    select 'int8', to_variant(i8) from typed
    union all
    select 'serial', to_variant(_row_id) from typed
    union all
    select 'float4', to_variant(f4) from typed
    union all
    select 'float8', to_variant(f8) from typed
    union all
    select 'decimal', to_variant(dec) from typed
    union all
    select 'varchar', to_variant(str) from typed
    union all
    select 'bytea', to_variant(bin) from typed
    union all
    select 'date', to_variant(d) from typed
    union all
    select 'time', to_variant(tm) from typed
    union all
    select 'timestamp', to_variant(ts) from typed
    union all
    select 'timestamptz', to_variant(tstz) from typed
    union all
    select 'jsonb', to_variant(js) from typed
    union all
    select 'list', to_variant(arr) from typed
    union all
    select 'struct', to_variant(st) from typed
    union all
    select 'map', to_variant(mp) from typed
    union all
    select 'variant', to_variant(to_variant(i4)) from typed
)
select input_type, variant_typeof(value) from variants;
----
boolean boolean
bytea binary
date date
decimal decimal16
float4 double
float8 double
int2 int16
int4 int32
int8 int64
jsonb object
list array
map object
parse_json_array array
parse_json_boolean boolean
parse_json_float double
parse_json_integer int64
parse_json_null null
parse_json_object object
parse_json_string string
serial int64
sql_null null
struct object
time time
timestamp timestamp_ntz_micros
timestamptz timestamp_micros
varchar string
variant int32

query TT
select
    variant_typeof(variant_get(to_variant(map {'k': 1}), '$.k')),
    variant_typeof(variant_get(to_variant(map {1: 10}), '$["1"]'));
----
int32 int32

query TTTTTTTTT
with v as (
    select parse_variant('{"a":[1,1.5,true,null,"x",{"b":[2]}]}') as value
)
select
    variant_typeof(variant_get(value, '$.a')),
    variant_typeof(variant_get(value, '$.a[0]')),
    variant_typeof(variant_get(value, '$.a[1]')),
    variant_typeof(variant_get(value, '$.a[2]')),
    variant_typeof(variant_get(value, '$.a[3]')),
    variant_typeof(variant_get(value, '$.a[4]')),
    variant_typeof(variant_get(value, '$.a[5]')),
    variant_typeof(variant_get(value, '$.a[5].b')),
    variant_typeof(variant_get(value, '$.a[5].b[0]'))
from v;
----
array int64 double boolean null string object array int64

query BBB
with v as (
    select parse_variant('{"a":[1]}') as value
)
select
    variant_get(value, '$.missing') is null,
    try_variant_get(value, '$.') is null,
    try_variant_get(value, '$.missing') is null
from v;
----
t t t

statement error invalid variant path
select variant_get(parse_variant('{"a":[1]}'), '$.');

query TTTTTTT
with v as (
    select
        to_variant(array[array[1, 2], array[3, 4]]::integer[][]) as nested_ints,
        to_variant(array[
            to_variant(1::smallint),
            to_variant(1::integer),
            parse_variant('1')
        ]::variant[]) as variant_values
)
select
    variant_typeof(nested_ints),
    variant_typeof(variant_get(nested_ints, '$[0]')),
    variant_typeof(variant_get(nested_ints, '$[0][0]')),
    variant_typeof(variant_values),
    variant_typeof(variant_get(variant_values, '$[0]')),
    variant_typeof(variant_get(variant_values, '$[1]')),
    variant_typeof(variant_get(variant_values, '$[2]'))
from v;
----
array array int32 array int16 int32 int64

statement error cannot be converted to variant
select to_variant(interval '1 day');

statement error cannot be converted to variant
select to_variant(hex_to_int256('0x11'));

statement error cannot be converted to variant
select to_variant('[1,2,3]'::vector(3));

