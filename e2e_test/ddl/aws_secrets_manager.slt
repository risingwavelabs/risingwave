# Test AWS Secrets Manager secret backend with LocalStack.
# The ALTER SYSTEM statement keeps this file out of the parallel ddl SLT lane.

control substitution on

statement ok
ALTER SYSTEM SET license_key TO DEFAULT;

sleep 1s

system ok
localstack_secretsmanager.py start

system ok
localstack_secretsmanager.py put --name rw-json-secret --secret-string '{"password":"rw-localstack-password","port":4566}'

system ok
localstack_secretsmanager.py put --name rw-raw-secret --secret-string 'rw-localstack-raw-secret'

statement ok
CREATE SECRET aws_sm_access_key WITH (
  backend = 'meta'
) AS 'test';

statement ok
CREATE SECRET aws_sm_secret_access_key WITH (
  backend = 'meta'
) AS 'test';

# CREATE SECRET validates the remote secret through LocalStack and extracts the JSON field.
statement ok
CREATE SECRET aws_sm_password WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  aws.region = 'us-east-1',
  endpoint_url = 'http://127.0.0.1:14566',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  field = 'password'
) AS NULL;

query T rowsort
SHOW SECRETS;
----
public.aws_sm_access_key
public.aws_sm_password
public.aws_sm_secret_access_key

# Nested credential SECRET refs must create catalog dependencies.
statement error secret public.aws_sm_password depends on it
DROP SECRET aws_sm_access_key;

# ALTER SECRET should reject cycles introduced through nested credential SECRET refs.
statement error cyclic secret reference detected
ALTER SECRET aws_sm_access_key WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-raw-secret',
  region = 'us-east-1',
  endpoint_url = 'http://127.0.0.1:14566',
  access_key_id = SECRET aws_sm_password,
  secret_access_key = SECRET aws_sm_secret_access_key
) AS NULL;

statement error Field 'missing' not found in secret
CREATE SECRET aws_sm_missing_field WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  region = 'us-east-1',
  endpoint_url = 'http://127.0.0.1:14566',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  field = 'missing'
) AS NULL;

statement error unknown field
CREATE SECRET aws_sm_unknown_option WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  region = 'us-east-1',
  endpoint_url = 'http://127.0.0.1:14566',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  unknown_option = 'bad'
) AS NULL;

statement error Duplicate AWS Secrets Manager option
CREATE SECRET aws_sm_duplicate_alias WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  region = 'us-east-1',
  aws.region = 'us-west-2',
  endpoint_url = 'http://127.0.0.1:14566',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key
) AS NULL;

statement ok
DROP SECRET aws_sm_password;

statement ok
DROP SECRET aws_sm_access_key;

statement ok
DROP SECRET aws_sm_secret_access_key;

system ok
localstack_secretsmanager.py stop
