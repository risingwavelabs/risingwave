# Test AWS Secrets Manager secret backend with LocalStack.
# The ALTER SYSTEM statement keeps this file out of the parallel ddl SLT lane.

control substitution on

statement ok
ALTER SYSTEM SET license_key TO DEFAULT;

statement ok
DROP USER IF EXISTS aws_sm_acl_user;

sleep 1s

system ok
localstack_secretsmanager.py start

system ok
localstack_secretsmanager.py put --name rw-json-secret --secret-string '{"password":"rw-localstack-password","port":4566}'

system ok
localstack_secretsmanager.py put --name rw-raw-secret --secret-string 'rw-localstack-raw-secret'

system ok
localstack_secretsmanager.py put --name rw-array-secret --secret-string '["not-object"]'

statement ok
CREATE SECRET aws_sm_access_key WITH (
  backend = 'meta'
) AS 'test';

statement ok
CREATE SECRET aws_sm_secret_access_key WITH (
  backend = 'meta'
) AS 'test';

statement ok
CREATE SECRET aws_sm_session_token WITH (
  backend = 'meta'
) AS 'test-session-token';

statement error session_token SECRET reference cannot be used with endpoint_url
CREATE SECRET aws_sm_session_token_endpoint WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  region = 'us-east-1',
  endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  session_token = SECRET aws_sm_session_token,
  field = 'password'
) AS NULL;

statement ok
CREATE USER aws_sm_acl_user WITH PASSWORD 'password';

statement ok
GRANT USAGE, CREATE ON SCHEMA public TO aws_sm_acl_user;

# Nested credential SECRET refs must still require USAGE on the referenced secret.
system ok
bash -c "set -euo pipefail; out=\$(PGPASSWORD=password psql -h \"\$SLT_HOST\" -p \"\$SLT_PORT\" -U aws_sm_acl_user -d \"\$SLT_DB\" -Atc \"CREATE SECRET aws_sm_acl_denied WITH (backend = 'aws_secrets_manager', secret_id = 'rw-json-secret', region = 'us-east-1', endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}', access_key_id = SECRET aws_sm_access_key, secret_access_key = SECRET aws_sm_secret_access_key, field = 'password') AS NULL;\" 2>&1 || true); grep -Eiq 'permission denied|not enough privileges|privilege' <<<\"\$out\""

statement ok
CREATE SCHEMA aws_sm_protected;

statement ok
GRANT USAGE ON SECRET aws_sm_access_key TO aws_sm_acl_user;

statement ok
GRANT USAGE ON SECRET aws_sm_secret_access_key TO aws_sm_acl_user;

# Target schema CREATE privilege must be checked before resolving credential refs or dialing AWS.
system ok
bash -c "set -euo pipefail; out=\$(PGPASSWORD=password psql -h \"\$SLT_HOST\" -p \"\$SLT_PORT\" -U aws_sm_acl_user -d \"\$SLT_DB\" -Atc \"CREATE SECRET aws_sm_protected.aws_sm_create_denied WITH (backend = 'aws_secrets_manager', secret_id = 'rw-json-secret', region = 'us-east-1', endpoint_url = 'http://127.0.0.1:1', access_key_id = SECRET aws_sm_access_key, secret_access_key = SECRET aws_sm_secret_access_key, field = 'password') AS NULL;\" 2>&1 || true); grep -Eiq 'permission denied|not enough privileges|privilege' <<<\"\$out\""

# CREATE SECRET validates the remote secret through LocalStack and extracts the JSON field.
statement ok
CREATE SECRET aws_sm_password WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  aws.region = 'us-east-1',
  endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  field = 'password'
) AS NULL;

query T rowsort
SHOW SECRETS;
----
public.aws_sm_access_key
public.aws_sm_password
public.aws_sm_secret_access_key
public.aws_sm_session_token

# Secret-to-secret dependencies are internal and should not be exposed through rw_depend.
query I
SELECT count(*)::int FROM rw_depend
WHERE objid = (SELECT id FROM rw_secrets WHERE name = 'aws_sm_password')
  AND refobjid IN (
    SELECT id FROM rw_secrets WHERE name IN ('aws_sm_access_key', 'aws_sm_secret_access_key')
  );
----
0

# Nested credential SECRET refs must create catalog dependencies.
statement error secret depends on it
DROP SECRET aws_sm_access_key;

# ALTER SECRET should reject cycles introduced through nested credential SECRET refs.
statement error cyclic secret reference detected
ALTER SECRET aws_sm_access_key WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-raw-secret',
  region = 'us-east-1',
  endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}',
  access_key_id = SECRET aws_sm_password,
  secret_access_key = SECRET aws_sm_secret_access_key
) AS NULL;

statement error Field 'missing' not found in secret
CREATE SECRET aws_sm_missing_field WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  region = 'us-east-1',
  endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  field = 'missing'
) AS NULL;

statement error requires the secret value to be a JSON object
CREATE SECRET aws_sm_non_object_json WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-array-secret',
  region = 'us-east-1',
  endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  field = 'password'
) AS NULL;

statement error unknown field
CREATE SECRET aws_sm_unknown_option WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  region = 'us-east-1',
  endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key,
  unknown_option = 'bad'
) AS NULL;

statement error Duplicate AWS Secrets Manager option
CREATE SECRET aws_sm_duplicate_alias WITH (
  backend = 'aws_secrets_manager',
  secret_id = 'rw-json-secret',
  region = 'us-east-1',
  aws.region = 'us-west-2',
  endpoint_url = '${LOCALSTACK_SECRETSMANAGER_ENDPOINT}',
  access_key_id = SECRET aws_sm_access_key,
  secret_access_key = SECRET aws_sm_secret_access_key
) AS NULL;

statement ok
DROP SECRET aws_sm_password;

statement ok
REVOKE USAGE ON SECRET aws_sm_access_key FROM aws_sm_acl_user;

statement ok
REVOKE USAGE ON SECRET aws_sm_secret_access_key FROM aws_sm_acl_user;

statement ok
DROP SECRET aws_sm_access_key;

statement ok
DROP SECRET aws_sm_secret_access_key;

statement ok
DROP SECRET aws_sm_session_token;

statement ok
DROP SCHEMA aws_sm_protected;

statement ok
REVOKE USAGE, CREATE ON SCHEMA public FROM aws_sm_acl_user;

statement ok
DROP USER aws_sm_acl_user;

system ok
localstack_secretsmanager.py stop
