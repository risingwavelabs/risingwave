# Test on join condition
statement ok
create schema s1;

statement ok
create schema s2;

statement ok
create table s1.a(id int, a int);

statement ok
create table s2.a(id int, b int);

statement ok
insert into s1.a values (1, 2), (2, 3), (3, 4);

statement ok
insert into s2.a values (1, 10), (4, 40);

query II
select s1.a.a, s2.a.b
from s1.a
join s2.a
on s1.a.id = s2.a.id
order by 1, 2;
----
2 10

query II
select a1.a, a2.b
from s1.a AS a1
join s2.a AS a2
on a1.id = a2.id
order by 1, 2;
----
2 10

statement error
select a, b from s1.a AS a1 join s2.a AS a2 on s1.a.id = s2.a.id;

statement ok
DROP TABLE s1.a;

statement ok
DROP TABLE s2.a;

statement ok
DROP SCHEMA s1;

statement ok
DROP SCHEMA s2;

