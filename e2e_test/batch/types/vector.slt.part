statement ok
SET RW_IMPLICIT_FLUSH TO true;

# Basic Usage derived from https://github.com/pgvector/pgvector/blob/v0.8.0/README.md#getting-started

statement ok
CREATE TABLE items (id bigint PRIMARY KEY, embedding vector(3));

statement ok
INSERT INTO items (embedding, id) VALUES ('[1,2,3]', 1), ('[4,5,6]', 2);

query
SELECT * FROM items ORDER BY id;
----
1 [1,2,3]
2 [4,5,6]

query
SELECT * FROM items ORDER BY embedding <-> '[3,1,2]' LIMIT 5;
----
1 [1,2,3]
2 [4,5,6]

query
SELECT * FROM items WHERE id != 1 ORDER BY embedding <-> (SELECT embedding FROM items WHERE id = 1) LIMIT 5;
----
2 [4,5,6]

query
SELECT * FROM items WHERE embedding <-> '[3,1,2]' < 5;
----
1 [1,2,3]

statement ok
DROP TABLE items;

statement ok
create table embedding_pk(embedding vector(3) primary key, id int);

statement ok
INSERT INTO embedding_pk (embedding, id) VALUES ('[1,2,3]', 1), ('[4,5,6]', 2);

query
SELECT id, embedding FROM embedding_pk ORDER BY embedding;
----
1 [1,2,3]
2 [4,5,6]

statement ok
drop table embedding_pk;

# Vector aggregates

query
select sum(embedding), avg(embedding)
from (values
    ('[1,2,3]'::vector(3)),
    ('[4,5,6]'::vector(3)),
    (null::vector(3))
) as t(embedding);
----
[5,7,9] [2.5,3.5,4.5]

query
select sum(embedding), avg(embedding)
from (select null::vector(3) as embedding) as t;
----
NULL NULL

query
select avg(embedding)
from (values
    ('[3e38,3e38,3e38]'::vector(3)),
    ('[3e38,3e38,3e38]'::vector(3))
) as t(embedding);
----
[300000000000000000000000000000000000000,300000000000000000000000000000000000000,300000000000000000000000000000000000000]

query
select avg(distinct embedding)
from (values
    ('[1,2,3]'::vector(3)),
    ('[1,2,3]'::vector(3))
) as t(embedding);
----
[1,2,3]
