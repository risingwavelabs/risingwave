statement ok
create table dt (a date, b varchar);

statement ok
insert into dt values (date('2020-01-23'), '1990-12-19');

query TT
select
    date(b)
from
dt
except
select
    cast(b as date)
from dt
except
select
    b::date
from dt;
----

statement ok
drop table dt;

query T
select date('2030-03-30');
----
2030-03-30

query error
select date('2000-13-03');

query error
select date('00-00-33');

query error cannot cast type "integer" to "date" in Explicit context
select date(1);

query error unexpected arguments number
select date();

query ?
select cast('a' as char(1));
----
a

# since we don't support char type, cast to char(2) will be the same as cast to varchar, so its behavior is the same as cast to varchar and not the same as postgresql.
query ?
select 'a'::char(2) = 'a '::char(2);
----
f

query ?
select 'a'::varchar = 'a '::varchar;
----
f

# int <-> bytea explicit casts (PG18)

# int2 -> bytea (big-endian encoding)
query T
SELECT 1::int2::bytea;
----
\x0001

query T
SELECT 256::int2::bytea;
----
\x0100

query T
SELECT 0::int2::bytea;
----
\x0000

query T
SELECT (-1)::int2::bytea;
----
\xffff

# int4 -> bytea
query T
SELECT 1::int4::bytea;
----
\x00000001

query T
SELECT 65536::int4::bytea;
----
\x00010000

query T
SELECT (-1)::int4::bytea;
----
\xffffffff

# int8 -> bytea
query T
SELECT 1::int8::bytea;
----
\x0000000000000001

query T
SELECT (-1)::int8::bytea;
----
\xffffffffffffffff

# bytea -> int2
query I
SELECT '\x0001'::bytea::int2;
----
1

query I
SELECT '\xffff'::bytea::int2;
----
-1

query I
SELECT '\x0000'::bytea::int2;
----
0

# bytea -> int4
query I
SELECT '\x00000001'::bytea::int4;
----
1

query I
SELECT '\xffffffff'::bytea::int4;
----
-1

# bytea -> int8
query I
SELECT '\x0000000000000001'::bytea::int8;
----
1

query I
SELECT '\xffffffffffffffff'::bytea::int8;
----
-1

# Length mismatch errors
statement error
SELECT '\x00'::bytea::int2;

statement error
SELECT '\x000000'::bytea::int4;

statement error
SELECT '\x00000000000000'::bytea::int8;

# NULL handling
query T
SELECT NULL::int2::bytea;
----
NULL

query I
SELECT NULL::bytea::int2;
----
NULL
