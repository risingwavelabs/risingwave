query T
SELECT owner_role.rolname
FROM pg_catalog.pg_class cls
JOIN pg_catalog.pg_roles owner_role ON owner_role.oid = cls.relowner
WHERE cls.relname = 'owned_by_active_role';
----
rw_role_catalog_test

