       member_role.rolname,
       admin_option::text
FROM pg_catalog.pg_auth_members
JOIN pg_catalog.pg_roles role_role ON role_role.oid = roleid
JOIN pg_catalog.pg_roles member_role ON member_role.oid = member
WHERE role_role.rolname = 'rw_role_catalog_test'
  AND member_role.rolname = 'rw_role_member_test'
ORDER BY 1, 2;
