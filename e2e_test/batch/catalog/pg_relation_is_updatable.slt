statement ok
create table hasura_t (id int primary key, v int);

statement ok
create view hasura_v as select * from hasura_t;

statement ok
create materialized view hasura_mv as select * from hasura_t;

statement ok
create source hasura_s (id int, v int) with (
    connector = 'datagen',
    datagen.rows.per.second = '1',
    datagen.split.num = '1'
);

query I
select pg_catalog.pg_relation_is_updatable('hasura_t'::regclass, true);
----
28

query I
select pg_catalog.pg_relation_is_updatable('hasura_v'::regclass, true);
----
0

query I
select pg_catalog.pg_relation_is_updatable('hasura_mv'::regclass, true);
----
0

query I
select pg_catalog.pg_relation_is_updatable('hasura_s'::regclass, true);
----
0

statement ok
drop materialized view hasura_mv;

statement ok
drop view hasura_v;

statement ok
drop source hasura_s;

statement ok
drop table hasura_t;
