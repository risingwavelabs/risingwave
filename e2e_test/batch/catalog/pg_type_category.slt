query TT rowsort
select typname, typcategory
from pg_catalog.pg_type
where typname in ('int4', '_int4', 'varchar', 'bool', 'timestamp', 'interval', 'jsonb')
order by typname;
----
_int4 A
bool B
int4 N
interval T
jsonb U
timestamp D
varchar S
