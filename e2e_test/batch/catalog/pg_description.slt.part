query TIIIT
SELECT
    c.relname,
    (
        SELECT relname FROM pg_catalog.pg_class WHERE oid = d.classoid
    ) AS classoid,
    d.objsubid,
    d.description
FROM
    pg_catalog.pg_description d
    JOIN pg_catalog.pg_class c
        ON d.objoid = c.oid
WHERE c.relname = 'mv_t'
ORDER BY d.objsubid;
----
mv_t  rw_materialized_views  0  Materialized view description

