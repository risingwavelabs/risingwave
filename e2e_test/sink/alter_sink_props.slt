#
# Track the `ALTER SINK PROPS` feature
#

statement ok
set sink_decouple = false;

# Kafka: verify supported alter-on-fly props.
statement ok
CREATE TABLE t_alter_sink_cfg_kafka (
    id INT PRIMARY KEY,
    v1 VARCHAR
);

statement ok
CREATE SINK s_alter_sink_cfg_kafka FROM t_alter_sink_cfg_kafka WITH (
    connector = 'kafka',
    properties.bootstrap.server = 'message_queue:29092',
    topic = 'test-rw-sink-alter-connector-props',
    type = 'upsert',
    primary_key = 'id'
);

statement ok
ALTER SINK s_alter_sink_cfg_kafka CONNECTOR WITH (
    properties.allow.auto.create.topics = 'true',
    properties.batch.num.messages = '200000',
    properties.batch.size = '1000000',
    properties.enable.idempotence = 'true',
    properties.max.in.flight.requests.per.connection = '1',
    properties.message.max.bytes = '10485760',
    properties.message.send.max.retries = '10',
    properties.message.timeout.ms = '60000',
    properties.queue.buffering.max.kbytes = '20480',
    properties.queue.buffering.max.messages = '200000',
    properties.queue.buffering.max.ms = '1000',
    properties.request.required.acks = '1',
    properties.retry.backoff.ms = '200',
    properties.receive.message.max.bytes = '104857600'
);

query I
select count(*)
from rw_sinks
where name = 's_alter_sink_cfg_kafka'
  and definition ilike '%properties.allow."auto"."create".topics = ''true''%'
  and definition ilike '%properties.batch.size = ''1000000''%'
  and definition ilike '%properties.enable.idempotence = ''true''%'
  and definition ilike '%properties."max"."in".flight.requests.per."connection" = ''1''%'
  and definition ilike '%properties."message"."max".bytes = ''10485760''%'
  and definition ilike '%properties."message".send."max".retries = ''10''%'
  and definition ilike '%properties."message".timeout.ms = ''60000''%'
  and definition ilike '%properties.queue.buffering."max".kbytes = ''20480''%'
  and definition ilike '%properties.queue.buffering."max".messages = ''200000''%'
  and definition ilike '%properties.queue.buffering."max".ms = ''1000''%'
  and definition ilike '%properties.receive."message"."max".bytes = ''104857600''%'
  and definition ilike '%properties.request.required.acks = ''1''%'
  and definition ilike '%properties.retry.backoff.ms = ''200''%';
----
1

statement error Field 'topic' is not allowed to be altered on the fly for sink: kafka
ALTER SINK s_alter_sink_cfg_kafka CONNECTOR WITH (
    topic = 'test-rw-sink-alter-connector-props-2'
);

statement ok
DROP SINK s_alter_sink_cfg_kafka;

statement ok
DROP TABLE t_alter_sink_cfg_kafka;

# ClickHouse: verify commit_checkpoint_interval can be altered.
statement ok
CREATE TABLE t_alter_sink_cfg_ch (
    v1 INT PRIMARY KEY,
    v2 BIGINT
);

statement ok
CREATE MATERIALIZED VIEW mv_alter_sink_cfg_ch AS
SELECT * FROM t_alter_sink_cfg_ch;

statement ok
CREATE SINK s_alter_sink_cfg_ch AS
SELECT * FROM mv_alter_sink_cfg_ch
WITH (
    connector = 'clickhouse',
    type = 'append-only',
    force_append_only = 'true',
    clickhouse.url = 'http://clickhouse-server:8123',
    clickhouse.user = 'default',
    clickhouse.password = 'default',
    clickhouse.database = 'default',
    clickhouse.table = 'demo_test'
);

statement ok
ALTER SINK s_alter_sink_cfg_ch CONNECTOR WITH (
    commit_checkpoint_interval = '1'
);

query I
select count(*)
from rw_sinks
where name = 's_alter_sink_cfg_ch'
  and definition ILIKE '%commit_checkpoint_interval = ''1''%';
----
1

statement ok
DROP SINK s_alter_sink_cfg_ch;

statement ok
DROP MATERIALIZED VIEW mv_alter_sink_cfg_ch;

statement ok
DROP TABLE t_alter_sink_cfg_ch;

# StarRocks: verify commit_checkpoint_interval can be altered.
statement ok
CREATE TABLE t_alter_sink_cfg_sr (
    v1 INT PRIMARY KEY,
    v2 VARCHAR
);

statement ok
CREATE MATERIALIZED VIEW mv_alter_sink_cfg_sr AS
SELECT * FROM t_alter_sink_cfg_sr;

statement ok
CREATE SINK s_alter_sink_cfg_sr
FROM
    mv_alter_sink_cfg_sr WITH (
    connector = 'starrocks',
    type = 'upsert',
    starrocks.host = 'starrocks-fe-server',
    starrocks.mysqlport = '9030',
    starrocks.httpport = '8030',
    starrocks.user = 'users',
    starrocks.password = '123456',
    starrocks.database = 'demo',
    starrocks.table = 'demo_bhv_table',
    primary_key = 'v1'
);

statement ok
ALTER SINK s_alter_sink_cfg_sr CONNECTOR WITH (
    commit_checkpoint_interval = '1'
);

query I
select count(*)
from rw_sinks
where name = 's_alter_sink_cfg_sr'
  and definition ILIKE '%commit_checkpoint_interval%';
----
1

statement ok
DROP SINK s_alter_sink_cfg_sr;

statement ok
DROP MATERIALIZED VIEW mv_alter_sink_cfg_sr;

statement ok
DROP TABLE t_alter_sink_cfg_sr;

# DeltaLake: verify commit_checkpoint_interval can be altered.
statement ok
CREATE TABLE t_alter_sink_cfg_dl (
    v1 INT PRIMARY KEY,
    v2 VARCHAR
);

statement ok
CREATE MATERIALIZED VIEW mv_alter_sink_cfg_dl AS
SELECT * FROM t_alter_sink_cfg_dl;

statement ok
CREATE SECRET deltalake_alter_sink_cfg_secret WITH (
  backend = 'meta'
) as 'hummockadmin';

statement ok
CREATE SINK s_alter_sink_cfg_dl AS
SELECT * FROM mv_alter_sink_cfg_dl
WITH (
    connector = 'deltalake',
    type = 'append-only',
    force_append_only = 'true',
    location = 's3a://deltalake/deltalake-test',
    s3.access.key = 'hummockadmin',
    s3.secret.key = secret deltalake_alter_sink_cfg_secret,
    s3.endpoint = 'http://127.0.0.1:9301'
);

statement ok
ALTER SINK s_alter_sink_cfg_dl CONNECTOR WITH (
    commit_checkpoint_interval = '1'
);

query I
select count(*)
from rw_sinks
where name = 's_alter_sink_cfg_dl'
  and definition ILIKE '%commit_checkpoint_interval = ''1''%';
----
1

statement ok
DROP SINK s_alter_sink_cfg_dl;

statement ok
DROP SECRET deltalake_alter_sink_cfg_secret;

statement ok
DROP MATERIALIZED VIEW mv_alter_sink_cfg_dl;

statement ok
DROP TABLE t_alter_sink_cfg_dl;

# Iceberg: verify commit_checkpoint_interval can be altered.
system ok
sparksql --e "
DROP TABLE IF EXISTS demo.demo_db.e2e_alter_sink_cfg_iceberg PURGE;
CREATE TABLE demo.demo_db.e2e_alter_sink_cfg_iceberg(v1 int, v2 string) TBLPROPERTIES ('format-version'='2');
"

statement ok
CREATE TABLE t_alter_sink_cfg_iceberg (
    v1 INT PRIMARY KEY,
    v2 VARCHAR
);

statement ok
CREATE MATERIALIZED VIEW mv_alter_sink_cfg_iceberg AS
SELECT * FROM t_alter_sink_cfg_iceberg;

statement ok
CREATE SECRET iceberg_alter_sink_cfg_access_key WITH (
  backend = 'meta'
) as 'hummockadmin';

statement ok
CREATE SECRET iceberg_alter_sink_cfg_secret_key WITH (
  backend = 'meta'
) as 'hummockadmin';

statement ok
CREATE SINK s_alter_sink_cfg_iceberg AS
SELECT * FROM mv_alter_sink_cfg_iceberg
WITH (
    connector = 'iceberg',
    type = 'upsert',
    primary_key = 'v1',
    warehouse.path = 's3a://icebergdata',
    s3.endpoint = 'http://127.0.0.1:9301',
    s3.access.key = secret iceberg_alter_sink_cfg_access_key,
    s3.secret.key = secret iceberg_alter_sink_cfg_secret_key,
    s3.region = 'us-east-1',
    catalog.name = 'demo',
    catalog.type = 'storage',
    database.name = 'demo_db',
    table.name = 'e2e_alter_sink_cfg_iceberg'
);

statement ok
ALTER SINK s_alter_sink_cfg_iceberg CONNECTOR WITH (
    commit_checkpoint_interval = '1'
);

query I
select count(*)
from rw_sinks
where name = 's_alter_sink_cfg_iceberg'
  and definition ILIKE '%commit_checkpoint_interval = ''1''%';
----
1

statement ok
DROP SINK s_alter_sink_cfg_iceberg;

statement ok
DROP SECRET iceberg_alter_sink_cfg_access_key;

statement ok
DROP SECRET iceberg_alter_sink_cfg_secret_key;

statement ok
DROP MATERIALIZED VIEW mv_alter_sink_cfg_iceberg;

statement ok
DROP TABLE t_alter_sink_cfg_iceberg;

system ok
sparksql --e "DROP TABLE IF EXISTS demo.demo_db.e2e_alter_sink_cfg_iceberg PURGE;"
