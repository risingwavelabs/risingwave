control substitution on

system ok
clickhouse <<< 'DROP TABLE IF EXISTS demo_test;'

system ok
clickhouse <<'EOF'
CREATE TABLE demo_test(
  v1 Int32,
  v2 Int64,
  v3 String,
  v4 Enum16('A' = 1, 'B' = 2),
  v5 Decimal64(3),
  v6 JSON
) ENGINE = ReplacingMergeTree PRIMARY KEY (v1);
EOF

statement ok
set sink_decouple = false;

statement ok
CREATE TABLE t6 (v1 int primary key, v2 bigint, v3 varchar, v4 smallint, v5 decimal, v6 jsonb);

statement ok
CREATE MATERIALIZED VIEW mv6 AS SELECT * FROM t6;

statement ok
CREATE SINK s6 AS select mv6.v1 as v1, mv6.v2 as v2, mv6.v3 as v3, mv6.v4 as v4, mv6.v5 as v5,mv6.v6 as v6 from mv6 WITH (
    ${RISEDEV_CLICKHOUSE_WITH_OPTIONS_COMMON},
    type = 'append-only',
    force_append_only='true',
    clickhouse.table='demo_test',
);

statement ok
INSERT INTO t6 VALUES (1, 50, '1-50', 1, 1.1,'{"sd":123,"sda":23}'), (2, 2, '2-2', 2, 2.2,'{"sd":123,"sda":23}'), (3, 2, '3-2', 1, 3.3,'{"sd":123,"sda":23}'), (5, 2, '5-2', 2, 4.4,'{"sd":123,"sda":23}'), (8, 2, '8-2', 1, 'inf','{"sd":123,"sda":23}'), (13, 2, '13-2', 2, '-inf','{"sd":123,"sda":23}'), (21, 2, '21-2', 1, 'nan','{"sd":123,"sda":23}');

statement ok
FLUSH;

system ok
result=$(clickhouse <<'EOF'
SELECT count(),sum(v1),sum(v2),sum(v4 = 'A'),sum(v4 = 'B'),sum(v5 = toDecimal64(0, 3))
FROM demo_test
FORMAT TSVRaw;
EOF
)
if [ "$result" = $'7\t53\t62\t4\t3\t3' ]; then
  exit 0
fi
echo "$result"
exit 1

statement ok
DROP SINK s6;

statement ok
DROP MATERIALIZED VIEW mv6;

statement ok
DROP TABLE t6;

system ok
clickhouse <<< 'DROP TABLE IF EXISTS demo_test;' >/dev/null
