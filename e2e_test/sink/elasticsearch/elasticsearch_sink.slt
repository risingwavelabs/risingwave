control substitution on

system ok retry 30 backoff 1s
search GET '/' >/dev/null

system ok
for index in test test1 test_route; do
  search DELETE "/${index}" >/dev/null 2>&1 || true
done

statement ok
set sink_decouple = false;

statement ok
CREATE TABLE t7 (
  v1 int,
  v2 bigint,
  v3 varchar,
  d date,
  t time,
  ts timestamp,
  tz timestamptz,
  st struct<st1 int, st2 int>,
  primary key(v1,v3),
);

statement ok
CREATE TABLE test_route (
  v1 int primary key,
  v2 int,
  v3 varchar,
);

# Invalid field: foo, allowed fields: {"username", "url", "password"}
statement error
create connection es_conn_1 with (
  type = '${SEARCH_SINK_CONNECTION_TYPE}',
  foo = 'bar',
  url = '${SEARCH_SINK_URL}',
  username = '${SEARCH_SINK_USER}',
  password = '${SEARCH_SINK_PASSWORD}'
);

# please set the password when the username is set.
statement error
create connection es_conn_1 with (
  type = '${SEARCH_SINK_CONNECTION_TYPE}',
  url = '${SEARCH_SINK_URL}',
  username = '${SEARCH_SINK_USER}'
);

statement ok
create connection es_conn with (
  type = '${SEARCH_SINK_CONNECTION_TYPE}',
  url = '${SEARCH_SINK_URL}',
  username = '${SEARCH_SINK_USER}',
  password = '${SEARCH_SINK_PASSWORD}',
);

statement ok
CREATE SINK test_route_sink from test_route WITH (
    type = 'upsert',
    ${SEARCH_SINK_ROUTE_WITH_OPTIONS},
    index = 'test_route',
    routing_column = 'v3'
);

statement ok
CREATE SINK s7 from t7 WITH (
    type = 'upsert',
    ${SEARCH_SINK_WITH_OPTIONS_COMMON},
    index = 'test'
);

statement ok
CREATE SINK s8 from t7 WITH (
    type = 'upsert',
    ${SEARCH_SINK_WITH_OPTIONS_COMMON},
    index = 'test1',
    primary_key = 'v1,v3',
    delimiter = '_'
);

statement ok
INSERT INTO test_route VALUES
  (1,1,'test1'),
  (2,2,'test2'),
  (3,3,'test3');

statement ok
INSERT INTO t7 VALUES
  (1, 2, '1-2', '1970-01-01', '00:00:00', '1970-01-01 00:00:00', '1970-01-01 00:00:00Z',(1,1)),
  (2, 2, '2-2', '1970-01-01', '00:00:00', '1970-01-01 00:00:00', '1970-01-01 00:00:00Z',(2,2)),
  (3, 2, '3-2', '1970-01-01', '00:00:00.123456', '1970-01-01 00:00:00.123456', '1970-01-01 00:00:00.123456Z',(3,3)),
  (5, 2, '5-2', '1970-01-01', '20:00:00', '1970-01-01 00:00:00', '1970-01-01 00:00:00Z',(5,5)),
  (8, 2, '8-2', '1970-01-01', '20:00:00', '1970-01-01 00:00:00', '1970-01-01 00:00:00Z',(8,8)),
  (13, 2, '13-2', '1970-01-01', '20:00:00.123456', '1970-01-01 20:00:00.123456', '1970-01-01 20:00:00.123456Z',(13,13));

statement ok
FLUSH;

statement ok
INSERT INTO t7 VALUES (1, 50, '1-50', '2000-01-01', '00:00:00.123456', '2000-01-01 00:00:00.123456', '2000-01-01 00:00:00.123456Z',(1,1));

statement ok
update t7 set v2 = 55 where v1 = 2;

statement ok
FLUSH;

system ok retry 10 backoff 1s
test "$(search GET '/test/_count' | python3 -c "import json,sys; print(json.load(sys.stdin)['count'])")" = "6"

system ok retry 10 backoff 1s
test "$(search GET '/test/_search?size=20' | python3 -c "import json,sys; docs=json.load(sys.stdin)['hits']['hits']; print(sum(1 for d in docs if d['_source'].get('v2') == 55))")" = "1"

system ok retry 10 backoff 1s
test "$(search GET '/test/_search?size=20' | python3 -c "import json,sys; docs=json.load(sys.stdin)['hits']['hits']; print(sum(1 for d in docs if d['_source'].get('v2') == 50))")" = "1"

system ok retry 10 backoff 1s
test "$(search GET '/test1/_count' | python3 -c "import json,sys; print(json.load(sys.stdin)['count'])")" = "7"

system ok retry 10 backoff 1s
test "$(search GET '/test_route/_search?size=20' | python3 -c "import json,sys; docs=json.load(sys.stdin)['hits']['hits']; print(','.join(sorted(d.get('_routing', '') for d in docs)))")" = "test1,test2,test3"

statement ok
DROP SINK s7;

statement ok
DROP SINK s8;

statement ok
DROP SINK test_route_sink;

statement ok
DROP TABLE test_route;

statement ok
DROP TABLE t7;
