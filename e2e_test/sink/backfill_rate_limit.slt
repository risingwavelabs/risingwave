statement ok
set sink_decouple = true;

statement ok
create table t1 (v1 int);

statement ok
insert into t1 select * from generate_series(1, 1000);

statement ok
create sink kafaka_sink
AS
SELECT * FROM t1
with (
    properties.bootstrap.server = 'message_queue:29092',
    topic = 'test_sink_backfill_rate_limit',
    type = 'append-only',
    force_append_only='true',
    connector = 'kafka',
    backfill_rate_limit = 0,
);

statement ok
create table kafka_source (v1 int) with (
  connector = 'kafka',
  topic = 'kafka_source',
  properties.bootstrap.server = 'message_queue:29092',
  scan.startup.mode = 'earliest',
) FORMAT PLAIN ENCODE JSON

statement ok
flush;

sleep 3s

query I
select count(*) from kafka_source;
----
0

statement ok
INSERT TABLE t VALUES (1001);

statement ok
flush;

query I
select count(*) from kafka_source;
----
0

query I
alter sink kafka_sink set backfill_rate_limit to 1000;


sleep 3s


query I
select count(*) > 1 from kafka_source;
----
t

statement ok
DROP TABLE kafka_source;

statement ok
DROP SINK kafaka_sink;

statement ok
DROP TABLE t1;

statement ok
FLUSH;