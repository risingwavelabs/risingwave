create table snapshot_free_t (id int primary key, v1 int, v2 int);

statement ok
create sink snapshot_free_project_filter as
select id, v1 + 1 as projected_v1
from snapshot_free_t
where v2 > 10
with (connector = 'blackhole', snapshot = 'false');

