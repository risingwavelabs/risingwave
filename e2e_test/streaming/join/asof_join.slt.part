# Insert another at v2=6 with smaller PK
statement ok
insert into t2 values (1, 6, 10);

query IIIIII
select * from mv_pk_lt;
----
1 5 100 1 6 10

# Insert at v2=6 with even smaller PK
statement ok
insert into t2 values (1, 6, 5);

query IIIIII
select * from mv_pk_lt;
