# Rows that can never begin a match are evicted once finalized (rather than lingering and being
# re-scanned every watermark). This checks that eviction does not drop rows a later match needs.

statement ok
set streaming_parallelism = 1;

statement ok
set rw_implicit_flush to true;

statement ok
create table t (id int, ts int, v int, watermark for ts as ts - 10) append only;

statement ok
create materialized view mv_evict as
select * from t match_recognize (
  partition by id
  order by ts
  measures b.v as dip
  one row per match
  after match skip past last row
  pattern (a b)
  define a as a.v > 0, b as b.v < 0
);

# Leading rows with v = 0 are neither `a` (v > 0) nor `b` (v < 0); they cannot begin the pattern and
# are evicted. The match (up, down) at ts 4..5 must still be found; ts 6 finalizes it.
statement ok
insert into t values
  (1, 1, 0), (1, 2, 0), (1, 3, 0), (1, 4, 10), (1, 5, -1), (1, 6, 0),
  (0, 100, 0);

query II rowsort
select * from mv_evict;
----
1 -1

statement ok
drop materialized view mv_evict;

statement ok
drop table t;

# A row that *can begin* the pattern but is then blocked. For `(a b)`, an up-row (`a`) followed only
# by non-matching rows (neither `a` nor `b`) can never complete, because the next row is not `b`. The
# old eviction predicate ("can this row begin the pattern?") kept that `a` forever; the result must
# still be exactly the one genuine match later in the stream, with no leftover effect from the dead
# `a`.
statement ok
create table t2 (id int, ts int, v int, watermark for ts as ts - 10) append only;

statement ok
create materialized view mv_evict2 as
select * from t2 match_recognize (
  partition by id
  order by ts
  measures b.v as dip
  one row per match
  after match skip past last row
  pattern (a b)
  define a as a.v > 0, b as b.v < 0
);

# ts 1 is an `a` (v > 0) but ts 2,3 are neither `a` nor `b`, so the ts-1 `a` is a dead start. The
# real (up, down) match is at ts 4..5; ts 6 finalizes it.
statement ok
insert into t2 values
  (1, 1, 7), (1, 2, 0), (1, 3, 0), (1, 4, 9), (1, 5, -2), (1, 6, 0),
  (0, 100, 0);

query II rowsort
select * from mv_evict2;
----
1 -2

statement ok
drop materialized view mv_evict2;

statement ok
drop table t2;
