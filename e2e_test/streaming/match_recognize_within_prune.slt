# Streaming MATCH_RECOGNIZE WITHIN with a variable-length pattern. The bound is enforced *during*
# matching: a greedy `a+` is not allowed to extend past the span bound, so it yields the longest run
# that fits the window instead of overshooting and being rejected wholesale. This is the difference
# between pruning during traversal and a post-hoc span check.

statement ok
set streaming_parallelism = 1;

statement ok
set rw_implicit_flush to true;

statement ok
create table t (id int, ts int, v int, watermark for ts as ts - 10) append only;

# Greedy `a+` must stay WITHIN a span of 2 in the ORDER BY column.
statement ok
create materialized view mv_within_prune as
select * from t match_recognize (
  partition by id
  order by ts
  measures count(*) as n, min(a.ts) as t0, max(a.ts) as t1
  one row per match
  after match skip past last row
  pattern (a+)
  within 2
  define a as a.v > 0
);

# id=1 has two runs of `a` rows (v > 0): ts {0,1,2} and ts {5,6}. ts 100 has v = 0 (not `a`) and
# terminates the second run. Without pruning, greedy `a+` from ts 0 would grab {0,1,2,5,6}, a span
# of 6 > 2, and the whole match would be rejected. With pruning it stops at ts 2 (span 2), emits
# {0,1,2}, then a fresh match {5,6} (span 1) starts after the skip.
statement ok
insert into t values
  (1, 0, 1), (1, 1, 1), (1, 2, 1), (1, 5, 1), (1, 6, 1), (1, 100, 0),
  (0, 1000, 0);

query III rowsort
select * from mv_within_prune;
----
1 2 5 6
1 3 0 2

statement ok
drop materialized view mv_within_prune;

statement ok
drop table t;
