# Test: session window closed by watermark advancement alone.
# Verifies that EMIT ON WINDOW CLOSE emits session windows when the watermark
# advances past the session boundary, even without new rows in the same partition.

statement ok
set RW_IMPLICIT_FLUSH to true;

statement ok
set streaming_parallelism = 1;

statement ok
create table t (
    tm timestamp,
    foo int,
    bar int,
    watermark for tm as tm - interval '5 minutes'
) append only;

statement ok
create materialized view mv as
select
    tm, foo, bar,
    first_value(tm) over w as window_start,
    last_value(tm) over w as window_end,
    count(*) over w as cnt,
    last_value(foo) over w as latest_foo
from t
window w as (partition by bar order by tm session with gap '10 minutes')
emit on window close;

# Insert two rows into partition bar=1, forming one session [16:51, 16:56].
statement ok
insert into t values
  ('2023-05-06 16:51:00', 1, 1)
, ('2023-05-06 16:56:00', 2, 1)
;

# Nothing emitted yet - the session is not closed.
query I
select count(*) from mv;
----
0

# Insert a row into a DIFFERENT partition (bar=2) at a far-future time.
# This advances watermark to 17:20 - 5min = 17:15.
# bar=1's session minimal_next_start = 16:56 + 10min = 17:06.
# Since watermark (17:15) >= minimal_next_start (17:06), bar=1's session closes.
statement ok
insert into t values
  ('2023-05-06 17:20:00', 3, 2)
;

# bar=1's session should now be emitted (2 rows), closed by watermark.
query TiiTTIi rowsort retry 11 backoff 1s
select * from mv;
----
2023-05-06 16:51:00  1  1  2023-05-06 16:51:00  2023-05-06 16:56:00  2  2
2023-05-06 16:56:00  2  1  2023-05-06 16:51:00  2023-05-06 16:56:00  2  2

# Advance watermark further to close bar=2's session.
# Insert into bar=1 at 17:40. Watermark = 17:40 - 5min = 17:35.
# bar=2's session minimal_next_start = 17:20 + 10min = 17:30.
# Since watermark (17:35) >= minimal_next_start (17:30), bar=2's session closes.
statement ok
insert into t values
  ('2023-05-06 17:40:00', 4, 1)
;

query TiiTTIi rowsort retry 11 backoff 1s
select * from mv;
----
2023-05-06 16:51:00  1  1  2023-05-06 16:51:00  2023-05-06 16:56:00  2  2
2023-05-06 16:56:00  2  1  2023-05-06 16:51:00  2023-05-06 16:56:00  2  2
2023-05-06 17:20:00  3  2  2023-05-06 17:20:00  2023-05-06 17:20:00  1  3

statement ok
drop materialized view mv;

statement ok
drop table t;

statement ok
set streaming_parallelism = 0;
