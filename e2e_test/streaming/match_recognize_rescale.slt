# Streaming MATCH_RECOGNIZE across a rescale. The per-partition buffer is distributed by the partition
# key, so when the actor's vnode ownership changes (ALTER ... SET PARALLELISM), the in-memory buffer
# must be reloaded from the state table: partitions whose vnode moved away are dropped and newly-owned
# ones are picked up. This checks that partial matches buffered before the rescale still complete after.

statement ok
set rw_implicit_flush to true;

statement ok
set streaming_parallelism = 1;

statement ok
create table ts (id int, t int, v int, watermark for t as t - 10) append only;

statement ok
create materialized view mv_rescale as
select * from ts match_recognize (
  partition by id
  order by t
  measures b.v as dip
  one row per match
  after match skip past last row
  pattern (a b)
  define a as a.v > 0, b as b.v < 0
);

# Buffer the leading `a` row of each partition's match (partial matches) while parallelism is 1.
statement ok
insert into ts values (1, 1, 5), (2, 1, 5), (3, 1, 5), (4, 1, 5), (5, 1, 5);

# Rescale: the partitions' vnodes reassign across actors; each actor reloads its buffer from state.
statement ok
alter materialized view mv_rescale set parallelism = 4;

# Complete each match after the reshuffle, plus a trailing row per partition to finalize it and a
# high-`t` sentinel to advance the watermark.
statement ok
insert into ts values (1, 2, -1), (2, 2, -1), (3, 2, -1), (4, 2, -1), (5, 2, -1);

statement ok
insert into ts values (1, 3, 0), (2, 3, 0), (3, 3, 0), (4, 3, 0), (5, 3, 0), (0, 1000, 0);

query II rowsort
select * from mv_rescale;
----
1 -1
2 -1
3 -1
4 -1
5 -1

statement ok
drop materialized view mv_rescale;

statement ok
drop table ts;
