# Streaming MATCH_RECOGNIZE CLASSIFIER(): reports the pattern variable bound to the match's last
# row (FINAL semantics under ONE ROW PER MATCH), alongside ordinary column measures.

statement ok
set streaming_parallelism = 1;

statement ok
set rw_implicit_flush to true;

statement ok
create table t (id int, ts int, v int, watermark for ts as ts - 10) append only;

# CLASSIFIER() mixed with a normal column measure: the (a b) match ends on `b`, so cls = 'b'.
statement ok
create materialized view mv_cls as
select * from t match_recognize (
  partition by id
  order by ts
  measures classifier() as cls, b.v as dip
  one row per match
  after match skip past last row
  pattern (a b)
  define a as a.v > 0, b as b.v < 0
);

# id=1: up(10) down(-5) up(8) down(-3) up(2) -> two (a b) matches, both classified 'b'. The
#   trailing up(2) confirms the second match is maximal so it finalizes.
# id=0 ts=100: sentinel pushing the watermark to 90 so all id=1 rows finalize.
statement ok
insert into t values
  (1, 1, 10), (1, 2, -5), (1, 3, 8), (1, 4, -3), (1, 5, 2),
  (0, 100, 0);

query ITI rowsort
select * from mv_cls;
----
1 b -3
1 b -5

statement ok
drop materialized view mv_cls;

statement ok
drop table t;
