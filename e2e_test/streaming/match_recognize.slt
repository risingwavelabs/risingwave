# Streaming MATCH_RECOGNIZE (v1): append-only input, ONE ROW PER MATCH, scalar MEASURES.

statement ok
set streaming_parallelism = 1;

statement ok
create table t (id int, ts int, v int) append only;

# --- MV1: AFTER MATCH SKIP PAST LAST ROW, multiple matches per partition. ---
# Pattern up(a: v>0) then down(b: v<0); MEASURES the down value.
statement ok
create materialized view mv_past as
select * from t match_recognize (
  partition by id
  order by ts
  measures b.v as dip
  one row per match
  after match skip past last row
  pattern (a b)
  define a as a.v > 0, b as b.v < 0
);

# --- MV2: AFTER MATCH SKIP TO NEXT ROW, overlapping matches. ---
# Pattern (a a); MEASURES the second row's value.
statement ok
create materialized view mv_next as
select * from t match_recognize (
  partition by id
  order by ts
  measures a.v as v2
  one row per match
  after match skip to next row
  pattern (a a)
  define a as a.v > 0
);

# id=1: up(10) down(-5) up(8) down(-3) up(2) -> two (a b) matches, dip -5 and -3.
# id=2: 5 6 7 (all a) then -1 (not a) -> TO NEXT ROW gives (0,2) and (1,3) -> v2 = 6 and 7.
statement ok
insert into t values
  (1, 1, 10), (1, 2, -5), (1, 3, 8), (1, 4, -3), (1, 5, 2),
  (2, 1, 5),  (2, 2, 6),  (2, 3, 7), (2, 4, -1);

statement ok
flush;

# MV1: two matches in partition 1; partition 2 has no down-row so no match.
query II rowsort
select * from mv_past;
----
1 -3
1 -5

# MV2: partition 2 yields two overlapping (a a) matches; partition 1's a-rows are
# isolated by down-rows so no two consecutive a's.
query II rowsort
select * from mv_next;
----
2 6
2 7

statement ok
drop materialized view mv_past;

statement ok
drop materialized view mv_next;

statement ok
drop table t;
