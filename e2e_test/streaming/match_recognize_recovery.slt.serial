# Recovery test for streaming MATCH_RECOGNIZE: a partial match buffered before recovery must be
# restored from the state table so it can complete afterwards.

# Single source parallelism so the watermark advances deterministically: with a parallel source the
# watermark is the min across partitions, and the single high-ts sentinel below would not advance it
# on a multi-node cluster, so the match would never finalise. (All the other MATCH_RECOGNIZE e2e
# tests set this for the same reason.)
statement ok
set streaming_parallelism = 1;

statement ok
set rw_implicit_flush to true;

statement ok
create table tr (id int, ts int, v int, watermark for ts as ts - 10) append only;

statement ok
create materialized view mvr as
select * from tr match_recognize (
  partition by id
  order by ts
  measures b.v as dip
  one row per match
  after match skip past last row
  pattern (a b)
  define a as a.v > 0, b as b.v < 0
);

# Buffer only the up-row (pattern variable `a`). The match is incomplete, so nothing is emitted yet.
statement ok
insert into tr values (1, 1, 10);

query II rowsort
select * from mvr;
----

# Trigger recovery: the executor must rebuild its per-partition buffer from the state table.
statement ok
recover;

# Wait for recovery to fully complete before feeding the completing rows. A fixed sleep races
# recovery on a loaded multi-node cluster: if the down-row arrives before the buffered `a` is
# restored, the match can never form. `wait` blocks until the recovered jobs are running again.
statement ok
wait;

# `recover` resets session state, so re-enable implicit flush for synchronous inserts below.
statement ok
set rw_implicit_flush to true;

# Complete the match after recovery with the down-row, a trailing up-row, and a high-ts sentinel
# that advances the watermark so the match finalises.
statement ok
insert into tr values (1, 2, -5), (1, 3, 8), (0, 100, 0);

sleep 5s

# The buffered `a` survived recovery, so the (a b) match completes and emits.
query II rowsort
select * from mvr;
----
1 -5

statement ok
drop materialized view mvr;

statement ok
drop table tr;
