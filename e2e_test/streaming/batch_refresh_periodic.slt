# Tests for the periodic-refresh trigger on batch-refresh materialized views.
#
# After the `refresh.interval.sec` elapses, a periodic refresh run should
# consume upstream changes and surface them in the batch-refresh MV.

statement ok
DROP MATERIALIZED VIEW IF EXISTS mv_batch;

statement ok
DROP MATERIALIZED VIEW IF EXISTS mv_up;

statement ok
DROP TABLE IF EXISTS t_batch;

statement ok
CREATE TABLE t_batch (v1 int);

statement ok
INSERT INTO t_batch VALUES (1), (2);

statement ok
CREATE MATERIALIZED VIEW mv_up AS SELECT * FROM t_batch;

statement ok
CREATE MATERIALIZED VIEW mv_batch WITH (refresh.interval.sec = 3) AS
SELECT * FROM mv_up;

# Initial snapshot.
query I rowsort
SELECT * FROM mv_batch;
----
1
2

# ─── first periodic refresh picks up new upstream rows ───────────────────────

statement ok
INSERT INTO t_batch VALUES (3), (4);

statement ok
FLUSH;

query I rowsort retry 5 backoff 1s
SELECT * FROM mv_up;
----
1
2
3
4

# Wait for at least one refresh cycle to kick in and complete. The retry
# window covers variance in the periodic trigger's firing time.
query I rowsort retry 15 backoff 1s
SELECT * FROM mv_batch;
----
1
2
3
4

# ─── second periodic refresh picks up further changes (incl. deletes) ────────

statement ok
DELETE FROM t_batch WHERE v1 = 1;

statement ok
INSERT INTO t_batch VALUES (5);

statement ok
FLUSH;

query I rowsort retry 5 backoff 1s
SELECT * FROM mv_up;
----
2
3
4
5

query I rowsort retry 15 backoff 1s
SELECT * FROM mv_batch;
----
2
3
4
5

statement ok
DROP MATERIALIZED VIEW mv_batch;

statement ok
DROP MATERIALIZED VIEW mv_up;

statement ok
DROP TABLE t_batch;
