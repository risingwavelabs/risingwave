# Streaming MATCH_RECOGNIZE WITHIN: a match whose span (last - first ORDER BY value) exceeds the
# bound is rejected. This is a streaming extension (Flink-style); BigQuery, being batch, has no
# WITHIN.

statement ok
set streaming_parallelism = 1;

statement ok
set rw_implicit_flush to true;

statement ok
create table t (id int, ts int, v int, watermark for ts as ts - 100) append only;

# (a b) must complete WITHIN a span of 3 in the ORDER BY column.
statement ok
create materialized view mv_within as
select * from t match_recognize (
  partition by id
  order by ts
  measures a.ts as t0, b.v as dip
  one row per match
  after match skip past last row
  pattern (a b)
  within 3
  define a as a.v > 0, b as b.v < 0
);

# id=1: (ts1 up, ts2 down) -> span 1 <= 3, matches. (ts10 up, ts14 down) -> span 4 > 3, rejected.
# ts15 finalizes the second (rejected) candidate; sentinel advances the watermark.
statement ok
insert into t values
  (1, 1, 5), (1, 2, -1), (1, 10, 5), (1, 14, -1), (1, 15, 9),
  (0, 1000, 0);

query III rowsort
select * from mv_within;
----
1 1 -1

statement ok
drop materialized view mv_within;

statement ok
drop table t;
