statement ok
SET RW_IMPLICIT_FLUSH TO true;

statement ok
create database d1;

statement ok
create database d2;

statement ok
set database to d1;

statement ok
create table t1(v1 int);

statement ok
insert into t1 select * from generate_series(1, 10000);

statement ok
create table t_order(id int primary key, k int, v int, ts timestamp);

statement ok
insert into t_order values (1, 1, 10, '2026-01-01 00:00:00');

statement ok
create materialized view mv_order_src as
select distinct on (k) k, v
from t_order
order by k, ts desc, id desc;

statement ok
set database to d2;

statement ok
set database to d1;

statement ok
create subscription sub from t1 with(retention = '1D');

statement ok
create subscription sub_order from mv_order_src with(retention = '1D');

statement ok
insert into t_order values (2, 1, 20, '2026-01-02 00:00:00');

statement ok
set database to d2;

query ok
select count(*) from d1.public.t1;
----
10000

statement ok
create materialized view mv_order_dst as select * from d1.public.mv_order_src;

query B
select count(*) > 0
from rw_catalog.rw_fragment_infos f
join rw_catalog.rw_materialized_views m on f.table_id = m.id
where m.name = 'mv_order_dst'
  and f.node::varchar like '%"streamScanType": "STREAM_SCAN_TYPE_CROSS_DB_SNAPSHOT_BACKFILL"%';
----
t

query ok
select * from mv_order_dst;
----
1 20

statement ok
set backfill_rate_limit = 200;

statement ok
set streaming_parallelism=2;

statement ok
set background_ddl=true;

statement ok
create materialized view mv1 as select * from d1.public.t1;

query ok
select count(*) from rw_ddl_progress;
----
1

sleep 2s

statement ok
recover

statement ok
wait

query ok
select count(*) from mv1;
----
10000

statement ok
set database to d1;

statement ok
create table t_rate_limit(v1 int);

statement ok
create subscription sub_rate_limit from t_rate_limit with(retention = '1D');

statement ok
set database to d2;

statement ok
create materialized view mv_rate_limit as select * from d1.public.t_rate_limit;

statement ok
wait

statement ok
alter materialized view mv_rate_limit set backfill_rate_limit = 0;

statement ok
set database to d1;

statement ok
insert into t_rate_limit select * from generate_series(1, 10000);

sleep 5s

statement ok
flush;

statement ok
set database to d2;

query ok
select count(*) from mv_rate_limit;
----
0

statement ok
alter materialized view mv_rate_limit set backfill_rate_limit = 1000;

statement ok
flush;

query ok retry 10 backoff 1s
select count(*) from mv_rate_limit;
----
10000

statement ok
set database to d2;

statement ok
drop materialized view mv_rate_limit;

statement ok
drop materialized view mv1;

statement ok
drop materialized view mv_order_dst;

statement ok
set database to d1;

statement ok
drop subscription sub_order;

statement ok
drop subscription sub_rate_limit;

statement ok
drop subscription sub;

statement ok
drop materialized view mv_order_src;

statement ok
drop table t_order;

statement ok
drop table t_rate_limit;

statement ok
drop table t1;

