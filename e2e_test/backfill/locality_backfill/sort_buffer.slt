statement ok
set enable_locality_backfill=true;

statement ok
set enable_locality_sort_buffer=true;

statement ok
create table t1(a int, b int, c int);

statement ok
create table t2(a int, b int, c int);

query T
explain create materialized view mv_sort_buffer as select count(*) from t1 join t2 on t1.a = t2.a group by t1.b;
----
StreamMaterialize { columns: [count, t1.b(hidden)], stream_key: [t1.b], pk_columns: [t1.b], pk_conflict: NoCheck }
└─StreamProject { exprs: [count, t1.b] }
  └─StreamHashAgg { group_key: [t1.b], aggs: [count] }
    └─StreamChangeBuffer
      └─StreamLocalityProvider { locality_columns: [t1.b] }
        └─StreamExchange { dist: HashShard(t1.b) }
              └─StreamHashJoin { type: Inner, predicate: t1.a = t2.a }
            ├─StreamExchange { dist: HashShard(t1.a) }
            │ └─StreamChangeBuffer
            │   └─StreamLocalityProvider { locality_columns: [t1.a] }
            │     └─StreamExchange { dist: HashShard(t1.a) }
                │       └─StreamTableScan { table: t1, columns: [a, b, _row_id] }
            └─StreamExchange { dist: HashShard(t2.a) }
              └─StreamChangeBuffer
                └─StreamLocalityProvider { locality_columns: [t2.a] }
                  └─StreamExchange { dist: HashShard(t2.a) }
                        └─StreamTableScan { table: t2, columns: [a, _row_id] }


statement ok
insert into t1 select 1001 - i, 123, i from generate_series(1, 1000, 1) i;

statement ok
insert into t2 select 1001 - i, 0, i from generate_series(1, 1000, 1) i;

statement ok
flush;

statement ok
create materialized view mv_sort_buffer as select count(*) from t1 join t2 on t1.a = t2.a group by t1.b;

query ?
select * from mv_sort_buffer;
----
1000

statement ok
insert into t1 values (1001, 123, 1001);

statement ok
insert into t2 values (1001, 0, 1001);

statement ok
flush;

query ?
select * from mv_sort_buffer;
----
1001

statement ok
drop materialized view mv_sort_buffer;

statement ok
drop table t1;

statement ok
drop table t2;
