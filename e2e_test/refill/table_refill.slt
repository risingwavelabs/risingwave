statement ok
create table t1(v1 int, v2 int);

statement ok
create table t2(v1 int, v3 int);

statement ok
create table t3(v1 int primary key, v2 int, v3 int);

statement ok
create sink s3 into t3 as select t1.v1, t1.v2, t2.v3 from t1 join t2 on t1.v1 = t2.v1;


query TTT
select name, key, value from rw_streaming_job_config;
---


statement ok
alter sink s3 set config(streaming.developer.cache_refill_policy = 'both');

query TTT
select name, key, value from rw_streaming_job_config;
----
s3  streaming.developer.cache_refill_policy "both"

skipif parallel
system ok
psql_refill_validate.py --job-name s3 --job-type sink --mode streaming --expect-policy both

statement ok
drop sink s3;

statement ok
drop table t3;

statement ok
drop table t2;

statement ok
drop table t1;