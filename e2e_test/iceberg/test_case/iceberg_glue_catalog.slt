statement ok
set sink_decouple = false;

statement ok
set streaming_parallelism=1;

statement ok
CREATE TABLE glue_rust_input (
    id int primary key,
    name varchar
);

statement ok
CREATE SINK glue_rust_sink AS SELECT * FROM glue_rust_input WITH (
    ${RISEDEV_GLUE_RUST_WITH_OPTIONS_COMMON},
    type = 'append-only',
    force_append_only = 'true',
    database.name = 'rw_glue_e2e',
    table.name = 'glue_rust_table',
    catalog.name = 'rw_glue_e2e',
    create_table_if_not_exists = 'true',
    commit_checkpoint_interval = 1
);

statement ok
INSERT INTO glue_rust_input VALUES (1, 'rust-a'), (2, 'rust-b');

statement ok
FLUSH;

statement ok
CREATE SOURCE glue_rust_source WITH (
    ${RISEDEV_GLUE_RUST_WITH_OPTIONS_COMMON},
    database.name = 'rw_glue_e2e',
    table.name = 'glue_rust_table',
    catalog.name = 'rw_glue_e2e'
);

query IT rowsort retry 6 backoff 1s
SELECT id, name FROM glue_rust_source;
----
1 rust-a
2 rust-b

