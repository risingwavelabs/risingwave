query I
select count(*)
from rw_sinks
where name = 's7'
  and connector_props -> 's3.secret.key' ->> 'type' = 'secret'
  and connector_props -> 's3.secret.key' -> 'value' ->> 'value' = 'iceberg_s3_secret_key_test';
----
1

