    connector = 'iceberg',
    warehouse.path = 's3a://icebergdata',
    s3.endpoint = 'http://127.0.0.1:9301',
    s3.access.key = secret iceberg_s3_access_key,
    s3.secret.key = secret iceberg_s3_secret_key,
    s3.region = 'us-east-1',
    catalog.name = 'demo',
    catalog.type = 'storage',
    database.name='demo_db',
    table.name='e2e_auto_schema_drop_table'
);

query TTTT
describe iceberg_auto_schema_drop_source;
----
id                       integer             false     NULL
keep_v                   character varying   false     NULL
_iceberg_sequence_number bigint              true      NULL
_iceberg_file_path       character varying   true      NULL
_iceberg_file_pos        bigint              true      NULL
_row_id                  serial              true      NULL
primary key              _row_id             NULL      NULL
table description        iceberg_auto_schema_drop_source NULL NULL

query TT retry 6 backoff 1s
SELECT id, keep_v FROM iceberg_auto_schema_drop_source ORDER BY id;
----
1 before
2 after

