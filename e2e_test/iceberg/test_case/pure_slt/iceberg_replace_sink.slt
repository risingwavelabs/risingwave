statement ok
CREATE TABLE t_iceberg_replace_sink_new (id int, v varchar);

statement ok
CREATE SINK s_iceberg_replace_sink_exactly_once FROM t_iceberg_replace_sink_old WITH (
    connector = 'iceberg',
    type = 'append-only',
    force_append_only = 'true',
    catalog.name = 'demo',
    database.name = 'demo_db',
    table.name = 'e2e_replace_sink_exactly_once_table',
    catalog.type = 'storage',
    warehouse.path = 's3a://icebergdata',
    s3.endpoint = 'http://127.0.0.1:9301',
    s3.region = 'us-east-1',
    s3.access.key = 'hummockadmin',
    s3.secret.key = 'hummockadmin',
    create_table_if_not_exists = 'true',
    snapshot = 'false',
    commit_checkpoint_interval = 1,
    is_exactly_once = 'true'
);

statement ok
