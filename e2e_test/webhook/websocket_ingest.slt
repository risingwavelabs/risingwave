# Simulation test for websocket ingest endpoint

control substitution on

statement ok
SET RW_IMPLICIT_FLUSH TO true;

statement ok
create table ws_orders (
  id int,
  customer_name varchar,
  product varchar,
  quantity int,
  price decimal,
  status varchar,
  created_at timestamp,
  primary key (id)
) WITH (
  connector = 'webhook'
) VALIDATE AS secure_compare(
  headers->>'x-rw-signature',
  'sha256=' || encode(hmac('TEST_WEBSOCKET', payload, 'sha256'), 'hex')
);

statement ok
create table ws_missing_pk (
  id int,
  customer_name varchar,
  amount double precision,
  primary key (id)
) WITH (
  connector = 'webhook'
) VALIDATE AS secure_compare(
  headers->>'x-rw-signature',
  'sha256=' || encode(hmac('TEST_WEBSOCKET', payload, 'sha256'), 'hex')
);

statement ok
create table ws_multi_column_no_pk (
  id int,
  customer_name varchar,
  amount double precision
) WITH (
  connector = 'webhook'
) VALIDATE AS secure_compare(
  headers->>'x-rw-signature',
  'sha256=' || encode(hmac('TEST_WEBSOCKET', payload, 'sha256'), 'hex')
);

statement ok
create table ws_single_jsonb_no_pk (
  data jsonb
) WITH (
  connector = 'webhook'
) VALIDATE AS secure_compare(
  headers->>'x-rw-signature',
  'sha256=' || encode(hmac('TEST_WEBSOCKET', data, 'sha256'), 'hex')
);

statement ok
create table ws_delete_only_pk (
  id int,
  customer_name varchar,
  amount double precision,
