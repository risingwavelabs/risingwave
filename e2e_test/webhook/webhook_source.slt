# Simulation test for table with webhook source

control substitution on

statement ok
SET RW_IMPLICIT_FLUSH TO true;

statement ok
CREATE SECRET test_secret WITH ( backend = 'meta') AS 'TEST_WEBHOOK';

include ./create_table.slt.part

# insert once
system ok
python3 e2e_test/webhook/sender.py --secret TEST_WEBHOOK

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":1234,"customer_name":"Alice","amount":99.99}' --expected-status '400' --expected-error 'unsupported webhook payload encode' --header 'x-rw-webhook-encode: csv'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":1234,"customer_name":"Alice","amount":99.99}' --expected-status '400' --expected-error 'unrecognized `x-rw-webhook-json-timestamp-handling-mode` value' --header 'x-rw-webhook-json-timestamp-handling-mode: invalid'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":1234,"customer_name":"Alice","amount":99.99}' --expected-status '400' --expected-error 'invalid webhook JSON decoder option' --header 'x-rw-webhook-json-timestamptz-handling-mode: invalid'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":1234,"customer_name":"Alice","amount":99.99}' --expected-status '400' --expected-error 'unrecognized `x-rw-webhook-json-time-handling-mode` value' --header 'x-rw-webhook-json-time-handling-mode: invalid'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":1234,"customer_name":"Alice","amount":99.99}' --expected-status '400' --expected-error 'unrecognized `x-rw-webhook-json-bigint-unsigned-handling-mode` value' --header 'x-rw-webhook-json-bigint-unsigned-handling-mode: invalid'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":1234,"customer_name":"Alice","amount":99.99}' --expected-status '400' --expected-error 'unrecognized `x-rw-webhook-json-handle-toast-columns` value' --header 'x-rw-webhook-json-handle-toast-columns: invalid'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":1234,"customer_name":"Alice",' --expected-status '422' --expected-error 'failed to decode webhook JSON payload'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"id":"not-an-int","customer_name":"Alice","amount":99.99}' --expected-status '422' --expected-error 'failed to decode webhook JSON payload'

system ok
python3 e2e_test/webhook/expect_failure.py --secret TEST_WEBHOOK --table multi_column_validate --payload '{"customer_name":"Alice","amount":99.99}' --expected-status '422' --expected-error 'failed to decode webhook JSON payload'

sleep 3s

# TODO(kexiang): will use a script to take place of check_1, check_2, check_3
include ./check_1.slt.part

# insert again
system ok
python3 e2e_test/webhook/sender.py --secret TEST_WEBHOOK

sleep 3s

include ./check_2.slt.part
