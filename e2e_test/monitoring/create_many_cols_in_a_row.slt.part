# Build a wide-row streaming graph to stress channel memory under backpressure:
# - datagen continuously generates rows
# - each source row has 100 varchar columns (c001..c100), making StreamChunks wide
# - low-cardinality join key (k) amplifies records across joins
# - when downstream is slow, many wide StreamChunks can accumulate in channels

statement ok
drop materialized view if exists mv2;

statement ok
drop materialized view if exists mv1;

statement ok
drop table if exists c;

statement ok
drop table if exists b;

statement ok
drop table if exists a;

